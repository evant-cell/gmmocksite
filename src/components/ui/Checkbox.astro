---
/** Checkbox control - heavy 2px raster, cobalt fill, supports indeterminate. */
import Icon from "./Icon.astro";

interface Props {
  name: string;
  label: string;
  checked?: boolean;
  indeterminate?: boolean;
  disabled?: boolean;
  class?: string;
}

const { name, label, checked = false, indeterminate = false, disabled = false, class: className = "" } = Astro.props;
---

<label class:list={["inline-flex items-center gap-3", disabled ? "cursor-not-allowed" : "cursor-pointer", className]}>
  <input
    type="checkbox"
    {name}
    checked={checked || indeterminate}
    {disabled}
    data-indeterminate={indeterminate || undefined}
    class="peer sr-only"
  />
  <span
    class="grid size-5 shrink-0 place-items-center border-2 border-ink bg-white text-transparent transition-colors
      peer-checked:border-cobalt peer-checked:bg-cobalt peer-checked:text-white
      peer-indeterminate:border-cobalt peer-indeterminate:bg-cobalt peer-indeterminate:text-white
      peer-disabled:border-line peer-disabled:bg-cloud
      peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-cobalt"
  >
    <Icon name={indeterminate ? "minus" : "check"} size={12} class="stroke-4" />
  </span>
  <span class:list={["text-sm font-medium", disabled && "text-mist"]}>{label}</span>
</label>

<script>
  document
    .querySelectorAll<HTMLInputElement>("input[data-indeterminate]")
    .forEach((el) => (el.indeterminate = true));
</script>
