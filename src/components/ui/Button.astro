---
/**
 * Button system - 5 semantic variants x 3 sizes, per Action UI spec.
 * Renders <a> when href is passed, <button> otherwise.
 */
import Icon from "./Icon.astro";
import type { IconName } from "./Icon.astro";

interface Props {
  variant?: "primary" | "secondary" | "tertiary" | "ghost" | "destructive";
  size?: "lg" | "md" | "sm";
  href?: string;
  type?: "button" | "submit" | "reset";
  disabled?: boolean;
  /** trailing icon, e.g. "arrow-right", "plus", "trash" */
  icon?: IconName;
  class?: string;
  [key: string]: unknown;
}

const {
  variant = "primary",
  size = "md",
  href,
  type = "button",
  disabled = false,
  icon,
  class: className = "",
  ...rest
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 gm-label transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cobalt";

const sizes = {
  lg: "h-13 px-8 text-xs",
  md: "h-11 px-6",
  sm: "h-9 px-5 text-[10px]",
};

const variants = {
  primary:
    "bg-raspberry text-white hover:bg-raspberry-deep aria-disabled:bg-raspberry-200 disabled:bg-raspberry-200",
  secondary:
    "border-2 border-ink text-ink hover:bg-ink hover:text-white aria-disabled:border-line aria-disabled:text-mist disabled:border-line disabled:text-mist disabled:hover:bg-transparent",
  tertiary:
    "bg-cobalt-100 text-cobalt hover:bg-cobalt hover:text-white aria-disabled:bg-cloud aria-disabled:text-mist disabled:bg-cloud disabled:text-mist",
  ghost:
    "text-ink hover:bg-ink/8 aria-disabled:text-mist disabled:text-mist disabled:hover:bg-transparent",
  destructive:
    "bg-error text-white hover:bg-error-deep aria-disabled:bg-error/30 disabled:bg-error/30",
};

const classes = [base, sizes[size], variants[variant], disabled && "pointer-events-none", className];
const iconSize = size === "sm" ? 14 : 16;
---

{
  href ? (
    <a href={disabled ? undefined : href} aria-disabled={disabled || undefined} class:list={classes} {...rest}>
      <slot />
      {icon && <Icon name={icon} size={iconSize} />}
    </a>
  ) : (
    <button {type} {disabled} class:list={classes} {...rest}>
      <slot />
      {icon && <Icon name={icon} size={iconSize} />}
    </button>
  )
}
