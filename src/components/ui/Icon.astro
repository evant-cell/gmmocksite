---
/** Programmatic UI vector pack - 24px grid, stroke-based. */
export type IconName =
  | "arrow-right"
  | "arrow-left"
  | "chevron-down"
  | "chevron-up"
  | "chevron-right"
  | "plus"
  | "minus"
  | "close"
  | "check"
  | "search"
  | "settings"
  | "user"
  | "heart"
  | "star"
  | "bell"
  | "mail"
  | "link"
  | "external-link"
  | "download"
  | "upload"
  | "menu"
  | "info"
  | "alert-triangle"
  | "alert-circle"
  | "clock"
  | "target"
  | "trash";

interface Props {
  name: IconName;
  size?: number;
  class?: string;
}

const paths: Record<IconName, string> = {
