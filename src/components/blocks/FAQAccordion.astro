---
/** Expandable FAQ rows with state-based chevron controls (native details/summary). */
import Icon from "../ui/Icon.astro";

interface Props {
  items: { question: string; answer: string; open?: boolean }[];
  class?: string;
}

const { items, class: className = "" } = Astro.props;
---

<div class:list={["divide-y divide-line border-y border-line", className]}>
  {
    items.map((item) => (
      <details class="group py-1" open={item.open}>
        <summary class="flex cursor-pointer list-none items-center justify-between gap-6 py-4 [&::-webkit-details-marker]:hidden">
          <h3 class="text-base font-bold">{item.question}</h3>
          <span class="grid size-8 shrink-0 place-items-center rounded-full bg-cloud text-ink transition-colors group-open:bg-raspberry group-open:text-white">
            <Icon name="chevron-down" size={15} class="transition-transform duration-200 group-open:rotate-180" />
          </span>
        </summary>
        <p class="max-w-3xl pb-5 text-sm leading-relaxed text-slate">{item.answer}</p>
      </details>
    ))
  }
</div>
