---
/**
 * Inline CMS edit-mode shell: fixed banner + a "Sections" menu that opens
 * one floating, draggable, resizable window per section, each holding only
 * that section's fields. Rendered by BaseLayout only when a page opts in via
 * `cmsPage`. Completely inert unless the URL carries `?edit=1` - regular
 * page loads render this markup but the module script below does nothing
 * beyond that check, so there is zero visible/behavioral difference for
 * normal visitors.
 *
 * See the CMS spec, section 4, for the full activation gate and state
 * machine this component's script implements.
 */
interface Props {
  /** Page slug, e.g. "home" or "platform". Matches the pages-main doc id. */
  page: string;
  /** The page's built-in content (same shape as the Firestore doc). */
  seed: unknown;
}

const { page, seed } = Astro.props;
---

<div data-cms-editor data-cms-page={page}>
  <script type="application/json" data-cms-seed set:html={JSON.stringify(seed)} />

  <div
    data-cms-banner
    hidden
    class="fixed inset-x-0 top-0 z-[200] flex h-11 items-center justify-between gap-4 border-b border-line-dark bg-ink px-4 text-white"
  >
    <div class="flex min-w-0 items-center gap-3 overflow-hidden">
      <span class="gm-label shrink-0 whitespace-nowrap text-[10px] text-white/70">
        Edit mode &middot; <span data-cms-slug>page</span>
      </span>
      <span
        data-cms-status
        data-tone="ok"
        class="gm-label shrink-0 rounded-full bg-white/10 px-2.5 py-1 text-[10px] whitespace-nowrap"
      >
        Saved
      </span>
      <span
        data-cms-remote-note
        hidden
        class="gm-label shrink-0 truncate text-[10px] text-warning-100"
      >
        Remote changed, your edits are unsaved
      </span>
    </div>
    <div class="flex shrink-0 items-center gap-2">
      <div class="relative">
        <button
          type="button"
          data-cms-sections-toggle
          aria-haspopup="true"
          aria-expanded="false"
          class="gm-label border border-white/25 px-3 py-1.5 text-[10px] whitespace-nowrap text-white transition-colors hover:bg-white/10"
        >
          Sections
        </button>
        <div
          data-cms-sections-menu
          hidden
          class="absolute top-full right-0 z-[210] mt-2 max-h-80 w-64 overflow-y-auto border border-line bg-white text-ink shadow-toast"
        >
        </div>
      </div>
      <button
        type="button"
        data-cms-save
        class="gm-label bg-raspberry px-3 py-1.5 text-[10px] whitespace-nowrap text-white transition-colors hover:bg-raspberry-deep"
      >
        Save
      </button>
      <button
        type="button"
        data-cms-discard
        class="gm-label border border-white/25 px-3 py-1.5 text-[10px] whitespace-nowrap text-white transition-colors hover:bg-white/10"
      >
        Discard
      </button>
      <!-- <button
        type="button"
        data-cms-reset
        hidden
        class="gm-label border border-warning/50 px-3 py-1.5 text-[10px] whitespace-nowrap text-warning-100 transition-colors hover:bg-white/10"
      >
        Reset to built-in
      </button> -->
      <button
        type="button"
        data-cms-exit
        class="gm-label border border-white/25 px-3 py-1.5 text-[10px] whitespace-nowrap text-white transition-colors hover:bg-white/10"
      >
        Exit
      </button>
    </div>
  </div>

  <div data-cms-windows class="pointer-events-none fixed inset-0 z-[150]"></div>
</div>

<style>
  .cms-field textarea {
    resize: none;
    overflow: hidden;
  }
  .cms-window {
    touch-action: none;
  }
  .cms-section-menu-item[data-open="true"] {
    background: var(--color-cloud);
  }
</style>

<script>
  import { watchAuth } from "../../lib/auth";
  import type { AuthState } from "../../lib/auth";
  import {
    getByPath,
    setByPath,
    enumerateFields,
    subscribePage,
    savePage,
    seedPageIfMissing,
    type CmsField,
    type PageDoc,
  } from "../../lib/cms";

  const root = document.querySelector<HTMLElement>("[data-cms-editor]");

  if (root) {
    const slug = root.dataset.cmsPage ?? "";
    const seedScript = root.querySelector<HTMLScriptElement>("[data-cms-seed]");
    const seed: PageDoc = seedScript ? (JSON.parse(seedScript.textContent ?? "null") as PageDoc) : {};

    // Reveal + wire the navbar "Edit this page" entry point unconditionally
    // (its own role-gated visibility is handled by Navbar's existing
    // data-requires-role logic). Runs regardless of ?edit=1, so a signed-in
    // editor can reach edit mode from a normal page load.
    document.querySelectorAll<HTMLAnchorElement>("[data-cms-edit-link]").forEach((a) => {
      a.removeAttribute("hidden");
      a.href = `${location.pathname}?edit=1`;
    });

    const params = new URLSearchParams(location.search);
    if (params.has("edit")) {
      const devBypass = import.meta.env.DEV && params.has("devcms");
      if (devBypass) {
        boot({ mode: "dev", user: null });
      } else {
        const unsub = watchAuth((state: AuthState) => {
          unsub();
          if (state.user && (state.role === "editor" || state.role === "admin")) {
            boot({ mode: "live", user: state.user });
          } else {
            stripEditParams();
          }
        });
      }
    }

    function stripEditParams() {
      const p = new URLSearchParams(location.search);
      p.delete("edit");
      p.delete("devcms");
      const qs = p.toString();
      history.replaceState(null, "", location.pathname + (qs ? `?${qs}` : "") + location.hash);
    }

    function cssEscape(value: string): string {
      if (typeof CSS !== "undefined" && CSS.escape) return CSS.escape(value);
      return value.replace(/[^a-zA-Z0-9_-]/g, "\\$&");
    }

    function deepEqual(a: unknown, b: unknown): boolean {
      return JSON.stringify(a) === JSON.stringify(b);
    }

    function closeIcon(): SVGSVGElement {
      const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
      svg.setAttribute("width", "14");
      svg.setAttribute("height", "14");
      svg.setAttribute("viewBox", "0 0 24 24");
      svg.setAttribute("fill", "none");
      svg.setAttribute("stroke", "currentColor");
      svg.setAttribute("stroke-width", "2");
      svg.setAttribute("stroke-linecap", "round");
      svg.setAttribute("stroke-linejoin", "round");
      svg.setAttribute("aria-hidden", "true");
      const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
      path.setAttribute("d", "M6 6l12 12M18 6 6 18");
      svg.appendChild(path);
      return svg;
    }

    function boot(ctx: { mode: "dev" | "live"; user: import("firebase/auth").User | null }) {
      document.documentElement.classList.add("gm-edit");

      const banner = root!.querySelector<HTMLElement>("[data-cms-banner]")!;
      const windowsLayer = root!.querySelector<HTMLElement>("[data-cms-windows]")!;
      const sectionsToggle = root!.querySelector<HTMLButtonElement>("[data-cms-sections-toggle]")!;
      const sectionsMenu = root!.querySelector<HTMLElement>("[data-cms-sections-menu]")!;
      const statusEl = root!.querySelector<HTMLElement>("[data-cms-status]")!;
      const remoteNoteEl = root!.querySelector<HTMLElement>("[data-cms-remote-note]")!;
      const slugEl = root!.querySelector<HTMLElement>("[data-cms-slug]")!;
      const resetBtn = root!.querySelector<HTMLButtonElement>("[data-cms-reset]")!;

      slugEl.textContent = slug;
      banner.removeAttribute("hidden");

      // Reset to built-in is destructive and admin-only, and only meaningful
      // once there is a live Firestore doc to reset.
      if (ctx.mode === "live") {
        watchAuth((state) => {
          resetBtn.toggleAttribute("hidden", state.role !== "admin");
        });
      }

      let working: PageDoc = structuredClone(seed);
      let saved: PageDoc = structuredClone(seed);
      let dirty = false;
      let initializedFromRemote = false;
      let unsubscribeRemote: (() => void) | null = null;

      // One floating window per section, keyed by group name. A window stays
      // open (position/size preserved) until its close button is clicked;
      // opening the same section again just brings it to front.
      const openWindows = new Map<string, { el: HTMLElement; body: HTMLElement }>();
      let topZ = 150;
      let cascadeCount = 0;

      function setStatus(text: string, tone: "ok" | "dirty" | "saving" | "error") {
        statusEl.textContent = text;
        statusEl.dataset.tone = tone;
      }

      function markDirty(next: boolean) {
        dirty = next;
        setStatus(next ? "Unsaved changes" : "Saved", next ? "dirty" : "ok");
      }

      function patchAll() {
        document.querySelectorAll<HTMLElement>("[data-cms-path]").forEach((el) => {
          const path = el.dataset.cmsPath;
          if (!path) return;
          const v = getByPath(working, path);
          if (typeof v === "string") el.textContent = v;
        });
      }

      function patchOne(path: string, value: string) {
        document
          .querySelectorAll<HTMLElement>(`[data-cms-path="${cssEscape(path)}"]`)
          .forEach((el) => (el.textContent = value));
      }

      function highlightPageNode(path: string) {
        const el = document.querySelector<HTMLElement>(`[data-cms-path="${cssEscape(path)}"]`);
        if (!el) return;
        el.scrollIntoView({ behavior: "smooth", block: "center" });
        el.classList.add("gm-cms-highlight");
        window.setTimeout(() => el.classList.remove("gm-cms-highlight"), 900);
      }

      function onFieldInput(path: string, value: string) {
        working = setByPath(working, path, value);
        patchOne(path, value);
        markDirty(!deepEqual(working, saved));
      }

      function buildFieldRow(field: CmsField): HTMLElement {
        const row = document.createElement("label");
        row.className = "cms-field flex flex-col gap-1.5 px-4 py-3";
        const labelSpan = document.createElement("span");
        labelSpan.className = "gm-label text-[10px] text-slate";
        labelSpan.textContent = field.label;
        row.appendChild(labelSpan);

        const isTextarea = field.kind === "textarea";
        const input: HTMLInputElement | HTMLTextAreaElement = isTextarea
          ? document.createElement("textarea")
          : document.createElement("input");
        if (input instanceof HTMLInputElement) input.type = "text";
        input.value = field.value;
        input.dataset.cmsFieldPath = field.path;
        input.className =
          "w-full border border-line bg-white px-3 py-2 text-sm text-ink focus:border-cobalt focus:outline-none";

        if (input instanceof HTMLTextAreaElement) {
          input.rows = 2;
          const autosize = () => {
            input.style.height = "auto";
            input.style.height = `${input.scrollHeight}px`;
          };
          input.addEventListener("input", autosize);
          window.requestAnimationFrame(autosize);
        }

        input.addEventListener("input", () => onFieldInput(field.path, input.value));
        input.addEventListener("focus", () => highlightPageNode(field.path));
        row.appendChild(input);
        return row;
      }

      /** Group names in first-seen order, e.g. for the Sections menu list. */
      function groupsInOrder(doc: PageDoc): string[] {
        const seenGroups: string[] = [];
        const seen = new Set<string>();
        for (const f of enumerateFields(doc)) {
          if (!seen.has(f.group)) {
            seen.add(f.group);
            seenGroups.push(f.group);
          }
        }
        return seenGroups;
      }

      function fieldsForGroup(doc: PageDoc, group: string): CmsField[] {
        return enumerateFields(doc).filter((f) => f.group === group);
      }

      function bringToFront(el: HTMLElement) {
        topZ += 1;
        el.style.zIndex = String(topZ);
      }

      function renderWindowBody(group: string, body: HTMLElement) {
        body.innerHTML = "";
        for (const f of fieldsForGroup(working, group)) body.appendChild(buildFieldRow(f));
      }

      function closeWindow(group: string) {
        const win = openWindows.get(group);
        if (!win) return;
        win.el.remove();
        openWindows.delete(group);
      }

      function wireDrag(handle: HTMLElement, win: HTMLElement) {
        handle.addEventListener("pointerdown", (e: PointerEvent) => {
          if (e.button !== 0) return;
          e.preventDefault();
          bringToFront(win);
          const startX = e.clientX;
          const startY = e.clientY;
          const rect = win.getBoundingClientRect();
          const startLeft = rect.left;
          const startTop = rect.top;

          const onMove = (ev: PointerEvent) => {
            const maxLeft = window.innerWidth - 60;
            const maxTop = window.innerHeight - 40;
            const nextLeft = startLeft + (ev.clientX - startX);
            const nextTop = startTop + (ev.clientY - startY);
            win.style.left = `${Math.min(Math.max(nextLeft, -(win.offsetWidth - 60)), maxLeft)}px`;
            win.style.top = `${Math.min(Math.max(nextTop, 0), maxTop)}px`;
          };
          const onUp = () => {
            document.removeEventListener("pointermove", onMove);
            document.removeEventListener("pointerup", onUp);
          };
          document.addEventListener("pointermove", onMove);
          document.addEventListener("pointerup", onUp);
        });
      }

      function createWindow(group: string): { el: HTMLElement; body: HTMLElement } {
        const el = document.createElement("div");
        el.className =
          "cms-window pointer-events-auto fixed flex resize flex-col overflow-hidden border border-line bg-white text-ink shadow-toast min-w-[280px] min-h-[220px] max-w-[92vw] max-h-[85vh]";
        const offset = 24 * (cascadeCount % 8);
        cascadeCount += 1;
        el.style.left = `${88 + offset}px`;
        el.style.top = `${64 + offset}px`;
        el.style.width = "380px";
        el.style.height = "420px";
        bringToFront(el);

        const header = document.createElement("div");
        header.className =
          "flex shrink-0 cursor-move items-center justify-between gap-2 border-b border-line bg-cloud px-3 py-2";
        const title = document.createElement("span");
        title.className = "gm-label truncate text-[10px] text-ink";
        title.textContent = group;
        const closeBtn = document.createElement("button");
        closeBtn.type = "button";
        closeBtn.setAttribute("aria-label", "Close section");
        closeBtn.className = "grid size-5 shrink-0 place-items-center text-slate transition-colors hover:text-ink";
        closeBtn.appendChild(closeIcon());
        closeBtn.addEventListener("click", () => closeWindow(group));
        header.appendChild(title);
        header.appendChild(closeBtn);

        const body = document.createElement("div");
        body.className = "min-h-0 flex-1 divide-y divide-line overflow-y-auto bg-white";

        el.appendChild(header);
        el.appendChild(body);

        el.addEventListener("pointerdown", () => bringToFront(el));
        wireDrag(header, el);

        return { el, body };
      }

      function openSectionWindow(group: string, focusPath?: string) {
        let win = openWindows.get(group);
        if (!win) {
          win = createWindow(group);
          openWindows.set(group, win);
          windowsLayer.appendChild(win.el);
          renderWindowBody(group, win.body);
        } else {
          bringToFront(win.el);
        }
        if (focusPath) {
          const input = win.body.querySelector<HTMLElement>(`[data-cms-field-path="${cssEscape(focusPath)}"]`);
          if (input) {
            input.scrollIntoView({ behavior: "smooth", block: "center" });
            input.focus();
          }
        }
      }

      function focusFieldForPath(path: string) {
        const field = enumerateFields(working).find((f) => f.path === path);
        if (!field) return;
        openSectionWindow(field.group, path);
      }

      function renderSectionsMenu() {
        sectionsMenu.innerHTML = "";
        for (const group of groupsInOrder(working)) {
          const item = document.createElement("button");
          item.type = "button";
          item.className =
            "cms-section-menu-item block w-full truncate px-4 py-2.5 text-left text-sm font-medium text-ink hover:bg-cloud";
          item.dataset.open = String(openWindows.has(group));
          item.textContent = group;
          item.addEventListener("click", () => {
            openSectionWindow(group);
            sectionsMenu.setAttribute("hidden", "");
            sectionsToggle.setAttribute("aria-expanded", "false");
          });
          sectionsMenu.appendChild(item);
        }
      }

      function refreshOpenWindows() {
        for (const [group, win] of openWindows) renderWindowBody(group, win.body);
      }

      function doDiscard() {
        working = structuredClone(saved);
        patchAll();
        refreshOpenWindows();
        markDirty(false);
        remoteNoteEl.setAttribute("hidden", "");
      }

      async function doSave() {
        setStatus("Saving", "saving");
        if (ctx.mode === "dev") {
          saved = structuredClone(working);
          markDirty(false);
          console.log("[cms:dev] save (local only, Firestore disabled)", saved);
          return;
        }
        try {
          await savePage(slug, working, ctx.user!);
          saved = structuredClone(working);
          markDirty(false);
        } catch (err) {
          console.error("[cms] save failed", err);
          setStatus("Error", "error");
        }
      }

      function doExit() {
        const p = new URLSearchParams(location.search);
        p.delete("edit");
        p.delete("devcms");
        const qs = p.toString();
        location.href = location.pathname + (qs ? `?${qs}` : "") + location.hash;
      }

      async function doReset() {
        if (ctx.mode !== "live") return;
        if (!window.confirm("Reset this page to the built-in content? This overwrites any saved edits.")) return;
        try {
          await savePage(slug, seed, ctx.user!);
        } catch (err) {
          console.error("[cms] reset failed", err);
          setStatus("Error", "error");
        }
      }

      sectionsToggle.addEventListener("click", () => {
        const willOpen = sectionsMenu.hasAttribute("hidden");
        if (willOpen) renderSectionsMenu();
        sectionsMenu.toggleAttribute("hidden", !willOpen);
        sectionsToggle.setAttribute("aria-expanded", String(willOpen));
      });
      document.addEventListener("pointerdown", (e) => {
        if (sectionsMenu.hasAttribute("hidden")) return;
        const target = e.target as Node;
        if (sectionsMenu.contains(target) || sectionsToggle.contains(target)) return;
        sectionsMenu.setAttribute("hidden", "");
        sectionsToggle.setAttribute("aria-expanded", "false");
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !sectionsMenu.hasAttribute("hidden")) {
          sectionsMenu.setAttribute("hidden", "");
          sectionsToggle.setAttribute("aria-expanded", "false");
        }
      });

      root!.querySelector("[data-cms-save]")!.addEventListener("click", () => void doSave());
      root!.querySelector("[data-cms-discard]")!.addEventListener("click", doDiscard);
      root!.querySelector("[data-cms-exit]")!.addEventListener("click", doExit);
      resetBtn.addEventListener("click", () => void doReset());

      // Reverse link: clicking a bound page node opens/focuses its section
      // window and that field within it. stopPropagation (not just
      // preventDefault) so the click is fully intercepted in edit mode -
      // otherwise a page's own click behavior on that same element (e.g. the
      // smooth-scroll-to-demo script on CTA links, or an accordion toggle)
      // would still fire alongside our editor.
      document.addEventListener(
        "click",
        (e) => {
          const target = (e.target as HTMLElement).closest<HTMLElement>("[data-cms-path]");
          if (!target) return;
          e.preventDefault();
          e.stopPropagation();
          focusFieldForPath(target.dataset.cmsPath!);
        },
        { capture: true },
      );

      window.addEventListener("beforeunload", (e) => {
        if (!dirty) return;
        e.preventDefault();
        e.returnValue = "";
      });

      patchAll();
      renderSectionsMenu();
      markDirty(false);

      if (ctx.mode === "live") {
        seedPageIfMissing(slug, seed, ctx.user!).catch((err) => console.error("[cms] seed failed", err));
        unsubscribeRemote = subscribePage(slug, (remote) => {
          if (!remote) return;
          if (!initializedFromRemote) {
            initializedFromRemote = true;
            working = structuredClone(remote);
            saved = structuredClone(remote);
            patchAll();
            refreshOpenWindows();
            renderSectionsMenu();
            markDirty(false);
            return;
          }
          if (deepEqual(remote, saved)) return;
          if (dirty) {
            remoteNoteEl.removeAttribute("hidden");
            return;
          }
          working = structuredClone(remote);
          saved = structuredClone(remote);
          patchAll();
          refreshOpenWindows();
          renderSectionsMenu();
        });
        window.addEventListener("pagehide", () => unsubscribeRemote?.(), { once: true });
      }
    }
  }
</script>
