---
/** Team profile card - portrait, name, role, social anchors. */
import Icon from "../ui/Icon.astro";

interface Props {
  name: string;
  role: string;
  src?: string;
  class?: string;
}

const { name, role, src, class: className = "" } = Astro.props;
---

<article class:list={["overflow-hidden border border-line bg-white", className]}>
  <div class="aspect-square w-full overflow-hidden bg-raspberry-100">
    {
      src ? (
        <img {src} alt={`Portrait of ${name}`} class="size-full object-cover" />
      ) : (
        <div class="grid size-full place-items-center bg-[radial-gradient(ellipse_at_50%_30%,#ffb8ce_0%,#f6f7fb_70%)]">
          <span class="font-display text-5xl font-extrabold text-raspberry/40">
            {name
              .split(" ")
              .map((n) => n[0])
              .join("")}
          </span>
        </div>
      )
    }
  </div>
  <div class="p-6">
    <h3 class="text-lg font-bold">{name}</h3>
    <p class="mt-1 text-sm text-slate">{role}</p>
    <div class="mt-4 flex gap-2">
      {
        (["link", "mail", "external-link"] as const).map((icon) => (
          <a
            href="#"
            aria-label={icon}
            class="grid size-8 place-items-center rounded-full bg-cloud text-slate transition-colors hover:bg-ink hover:text-white"
          >
            <Icon name={icon} size={13} />
          </a>
        ))
      }
    </div>
  </div>
</article>
