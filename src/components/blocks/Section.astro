---
/** Container / section wrapper - enforces the max-width content boundary and safe-zone padding. */
interface Props {
  theme?: "light" | "dark" | "white";
  /** vertical padding scale */
  spacing?: "none" | "md" | "lg";
  class?: string;
}

const { theme = "light", spacing = "lg", class: className = "" } = Astro.props;

const themes = {
  light: "bg-cloud text-ink",
  white: "bg-white text-ink",
  dark: "bg-ink text-white",
};
const spacings = { none: "", md: "py-12 md:py-16", lg: "py-16 md:py-24" };
---

<section class:list={[themes[theme], className]}>
  <div class:list={["mx-auto max-w-7xl px-6 lg:px-20", spacings[spacing]]}>
    <slot />
  </div>
</section>
