---
/** Global dark footer - brand blurb, four nav columns, socials, legal bar. */
import Logo from "../ui/Logo.astro";
import Icon from "../ui/Icon.astro";

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;

const columns = [
  {
    heading: "Products",
    links: ["Ad Engine", "Audience Builder", "Performance Hub", "Media Network"],
  },
  {
    heading: "Company",
    links: ["About Us", "Case Studies", "Press Room", "Careers"],
  },
  {
    heading: "Resources",
    links: ["API Docs", "Developer SDK", "System Status", "Support Desk"],
  },
  {
    heading: "Legal",
    links: ["Privacy Policy", "Terms of Use", "Opt Out", "GDPR Compliance"],
  },
];
---

<footer class:list={["bg-ink text-white", className]}>
  <div class="mx-auto max-w-7xl px-6 py-16 lg:px-10">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_repeat(4,1fr)]">
      <div>
        <Logo inverted class="text-2xl" />
        <p class="mt-5 max-w-xs text-sm leading-relaxed text-white/60">
          The next generation programmatic ad platform. Real-time media buying fueled by robust user
          behaviors and zero conversion-waste logic.
        </p>
        <div class="mt-6 flex gap-3">
          {
            (["link", "mail", "star", "heart"] as const).map((icon) => (
              <a
                href="#"
                aria-label={icon}
                class="grid size-9 place-items-center rounded-full bg-white/10 text-white/80 transition-colors hover:bg-raspberry hover:text-white"
              >
                <Icon name={icon} size={15} />
              </a>
            ))
          }
        </div>
      </div>

      {
        columns.map((col) => (
          <nav>
            <h4 class="text-sm font-bold">{col.heading}</h4>
            <ul class="mt-4 flex flex-col gap-2.5">
              {col.links.map((label) => (
                <li>
                  <a href="#" class="text-sm text-white/55 transition-colors hover:text-white">
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-line-dark pt-7 sm:flex-row sm:items-center">
      <p class="text-xs text-white/45">© 2026 Genius Monkey Inc. All proprietary technologies patented.</p>
      <p class="gm-label text-[10px] text-white/70">geniusmonkey.com</p>
    </div>
  </div>
</footer>
