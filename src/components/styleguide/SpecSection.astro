---
/** Numbered spec-sheet section - "01. Title", description line, rule. */
interface Props {
  number: string;
  title: string;
  description?: string;
  class?: string;
}

const { number, title, description, class: className = "" } = Astro.props;
---

<section class:list={["py-10", className]}>
  <h2 class="text-2xl font-bold">{number}. {title}</h2>
  {description && <p class="mt-1.5 text-sm text-slate">{description}</p>}
  <hr class="mt-4 mb-8 border-line" />
  <slot />
</section>
