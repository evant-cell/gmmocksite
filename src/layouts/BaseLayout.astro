---
import "@fontsource-variable/bricolage-grotesque";
import "@fontsource-variable/unbounded";
import "@fontsource-variable/outfit";
import "@fontsource-variable/google-sans-flex/full.css";
import "../styles/global.css";
import CmsEditor from "../components/blocks/CmsEditor.astro";

interface Props {
  title: string;
  description?: string;
  /** page path for the canonical URL, e.g. "/platform"; omit to skip canonical */
  path?: string;
  /** set true on internal pages (styleguide) to keep them out of search */
  noindex?: boolean;
  /** Inline CMS: page slug (e.g. "home", "platform"). Omit to leave the page uneditable. */
  cmsPage?: string;
  /** Inline CMS: the page's built-in content, used as the seed/fallback doc. */
  cmsSeed?: unknown;
}

const {
  title,
  description = "Genius Monkey - next generation programmatic ad platform.",
  path,
  noindex = false,
  cmsPage,
  cmsSeed,
} = Astro.props;

const canonical = path && Astro.site ? new URL(path, Astro.site).href : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Genius Monkey" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <slot name="head" />
  </head>
  <body data-cms-page={cmsPage}>
    {cmsPage && <CmsEditor page={cmsPage} seed={cmsSeed} />}
    <a
      href="#main-content"
      class="gm-label sr-only bg-ink px-4 py-2 text-white focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cobalt"
    >
      Skip to content
    </a>
    <slot />
  </body>
</html>

<style is:global>
  /* Inline CMS edit mode: room for the fixed banner, plus the shared
     highlight used to flash a bound page node when its panel field focuses.
     Both are no-ops unless a page opts in via cmsPage AND ?edit=1 resolves. */
  html.gm-edit body {
    padding-top: 2.75rem;
  }
  .gm-cms-highlight {
    outline: 2px solid var(--color-cobalt);
    outline-offset: 2px;
    transition: outline-color 0.2s ease;
  }
</style>
