---
import SpecShell from "../../components/styleguide/SpecShell.astro";
import SpecSection from "../../components/styleguide/SpecSection.astro";
import HeroMask from "../../components/blocks/HeroMask.astro";
import HeroTexture from "../../components/blocks/HeroTexture.astro";
import HeroCollision from "../../components/blocks/HeroCollision.astro";
import StatBlock from "../../components/blocks/StatBlock.astro";
import Button from "../../components/ui/Button.astro";
import TextLink from "../../components/ui/TextLink.astro";
import Logo from "../../components/ui/Logo.astro";

const paletteGroups = [
  {
    group: "Primary",
    swatches: [
      { name: "Vivid Raspberry", value: "#F7004E", pantone: "192 C", class: "bg-raspberry text-white" },
      { name: "Black Hole", value: "#020112", pantone: "Black 6 C", class: "bg-hole text-white" },
      { name: "White", value: "#FFFFFF", pantone: "11-0601 TPG", class: "bg-white text-ink border border-line" },
    ],
  },
  {
    group: "Neutrals",
    swatches: [
      { name: "Ink", value: "#10131A", class: "bg-ink text-white" },
      { name: "Slate", value: "#5B6472", class: "bg-slate text-white" },
      { name: "Cloud", value: "#F6F7FB", class: "bg-cloud text-ink border border-line" },
    ],
  },
  {
    group: "Secondary",
    swatches: [
      { name: "Brand Blue", value: "#3D5AFE", pantone: "2728 C", class: "bg-cobalt text-white" },
      { name: "Brand Violet", value: "#7C4DFF", pantone: "2095 C", class: "bg-violet text-white" },
      { name: "Brand Green", value: "#52E0B6", class: "bg-mint text-ink" },
    ],
  },
];

const gradients = [
  { name: "Brand Gradient", class: "bg-gradient-brand", usage: "Hero backgrounds, key CTAs, brand moments" },
  { name: "BG Dark Purple", class: "bg-gradient-dark-purple", usage: "Deep section backdrops" },
  { name: "BG Dark Green", class: "bg-gradient-dark-green", usage: "Deep section backdrops" },
  { name: "BG Dark Raspberry", class: "bg-gradient-dark-raspberry", usage: "High-impact brand moments" },
];

const typeScale = [
  { label: "Display · 48px / 700", class: "text-display" },
  { label: "Heading 1 · 34px / 900", class: "text-h1" },
  { label: "Heading 2 · 26px / 900", class: "text-h2" },
  { label: "Heading 3 · 22px / 600", class: "text-h3" },
  { label: "Heading 4 · 20px / 600", class: "text-h4" },
  { label: "Heading 5 · 18px / 600", class: "text-h5" },
  { label: "Heading 6 · 16px / 900", class: "text-h6" },
  { label: "Lead · 16px / 400", class: "text-lead" },
  { label: "Body · 16px / 400", class: "text-body" },
  { label: "Caption · 13px / 900", class: "text-caption" },
];
---

<SpecShell sheet="Brand Clipping & Mask Spec Sheet" version="V1.4.0">
  <SpecSection
    number="01"
    title="Brand Foundations"
    description="Wordmark, palette, and the three-family type system: Bricolage Grotesque display, Unbounded labels, Outfit body."
  >
    <div class="grid gap-8 lg:grid-cols-[auto_1fr]">
      <div class="flex flex-col items-start justify-center gap-6 bg-ink p-10">
        <Logo inverted class="text-4xl" />
        <Logo variant="inline" inverted class="text-xl" />
      </div>
      <div class="flex flex-col gap-6">
        {
          paletteGroups.map((g) => (
            <div>
              <p class="gm-label mb-3 text-[10px] text-slate">{g.group}</p>
              <div class="grid grid-cols-3 gap-3">
                {g.swatches.map((c) => (
                  <div class:list={["flex aspect-[4/3] flex-col justify-end p-4", c.class]}>
                    <p class="text-sm font-bold">{c.name}</p>
                    <p class="gm-label mt-0.5 text-[9px] opacity-70">{c.value}</p>
                    {c.pantone && <p class="text-[10px] opacity-60">Pantone {c.pantone}</p>}
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-8">
      <p class="gm-label mb-3 text-[10px] text-slate">Brand Gradients (135°)</p>
      <div class="grid grid-cols-2 gap-3 lg:grid-cols-4">
        {
          gradients.map((g) => (
            <div class:list={["flex aspect-[4/3] flex-col justify-end p-4 text-white", g.class]}>
              <p class="text-sm font-bold">{g.name}</p>
              <p class="text-[10px] opacity-70">{g.usage}</p>
            </div>
          ))
        }
      </div>
      <p class="mt-4 max-w-2xl text-sm text-slate">
        Aim for roughly 60% neutrals, 30% primary, and 10% accent across any given layout.
      </p>
    </div>
    <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      <div class="border border-line bg-white p-6">
        <p class="gm-label text-[10px] text-slate">Display · Bricolage Grotesque</p>
        <p class="mt-3 font-display text-4xl font-extrabold tracking-tight">Raw attention triggers.</p>
      </div>
      <div class="border border-line bg-white p-6">
        <p class="gm-label text-[10px] text-slate">Label · Unbounded</p>
        <p class="mt-3 gm-label text-base">Deploy Your Stream</p>
      </div>
      <div class="border border-line bg-white p-6">
        <p class="gm-label text-[10px] text-slate">Body · Outfit</p>
        <p class="mt-3 text-base leading-relaxed text-slate">
          Real-time media buying fueled by robust user behaviors and zero conversion-waste logic.
        </p>
      </div>
      <div class="border border-line bg-white p-6">
        <p class="gm-label text-[10px] text-slate">Flex · Google Sans Flex</p>
        <p class="mt-3 font-flex text-3xl font-bold tracking-tight">Adapts by size.</p>
        <p class="mt-2 font-flex text-sm text-slate">
          Variable wght + opsz axes, not tied to a fixed role.
        </p>
      </div>
    </div>
  </SpecSection>

  <SpecSection
    number="02"
    title="Type Scale"
    description="Size / line-height / weight tokens per the brand spec. Keep line length between 50-75 characters for body copy and avoid more than two weights per layout."
  >
    <div class="flex flex-col divide-y divide-line border border-line bg-white px-8">
      {
        typeScale.map((t) => (
          <div class="grid items-baseline gap-2 py-5 md:grid-cols-[220px_1fr] md:gap-8">
            <p class="text-xs font-medium text-slate">{t.label}</p>
            <p class:list={[t.class, "text-ink"]}>Programmatic Advertising always wins.</p>
          </div>
        ))
      }
    </div>
  </SpecSection>

  <SpecSection
    number="03"
    title="Logo as Image Mask - Hero"
    description="The wordmark treated as a high-contrast clipping aperture exposing a vivid generative field."
  >
    <HeroMask title="Programmatic delivery, visually redefined.">
      Our next-generation advertising ecosystem maps real-time user intention paths, forcing
      attention to convert. No waste. No legacy overhead. Just raw performance metrics.
      <Fragment slot="actions">
        <Button size="lg">Explore Mask Tech</Button>
        <p class="flex items-center gap-2 text-xs font-semibold text-white/70">
          <span class="size-2 rounded-full bg-success"></span>24.8k Active Bidders
        </p>
      </Fragment>
    </HeroMask>
  </SpecSection>

  <SpecSection
    number="04"
    title="Logo as Background Texture"
    description="Tiled wordmark repetition as an engineered back-pattern. Unconscious brand recall."
  >
    <HeroTexture eyebrow="02 / Integrated Texture" title="Unconscious brand recall.">
      By layering our programmatic manifestos and tiled wordmarks as background texture, we create a
      sense of deep engineering. The interface feels calculated, intentional, and massive.
      <Fragment slot="actions">
        <Button size="lg">Deploy Your Stream</Button>
      </Fragment>
    </HeroTexture>
  </SpecSection>

  <SpecSection
    number="05"
    title="Experimental Type + Logo Collision"
    description="Off-axis collision - massive display titles crash directly into a bleeding brand stamp."
  >
    <HeroCollision title="Collision is intent.">
      By driving high-end editorial titles directly across the barriers of photographic frames and
      bleeding brand marks, we destroy safe container design. The interface behaves like physical
      print catalog design.
      <Fragment slot="actions">
        <TextLink href="#" color="ink" class="text-white hover:text-white/70">Explore Creative Framework</TextLink>
      </Fragment>
    </HeroCollision>
  </SpecSection>

  <SpecSection
    number="06"
    title="Extreme Type Scale - Data Callout"
    description="Giant display figures anchoring behavioral data visual narratives."
  >
    <StatBlock value="40%" label="Average Cost Efficiency Improvement" noteTitle="Data Spec">
      Systematic testing reveals behavioral segment targeting drops acquisition overhead by nearly
      two-fifths across high-volume networks.
    </StatBlock>
  </SpecSection>
</SpecShell>
