---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";
import Button from "../components/ui/Button.astro";
import TextLink from "../components/ui/TextLink.astro";
import Icon from "../components/ui/Icon.astro";
import FAQAccordion from "../components/blocks/FAQAccordion.astro";
import DemoForm from "../components/blocks/DemoForm.astro";
import ChatWidget from "../components/blocks/ChatWidget.astro";

const page = await getEntry("pages", "home");
if (!page) throw new Error("Missing content: src/content/pages/home.json");
const data = page.data;

type Rate = { channel: string; value: string };
type Stat = {
  value?: string;
  label?: string;
  before?: string;
  valuePrefix?: string;
  countUp?: number;
  valueSuffix?: string;
  tag?: string;
  accent?: string;
};
type LinkRef = { text: string; href: string };
type Block = { kind: string; text?: string; links?: string[]; href?: string };
type Section = {
  type: string;
  eyebrow?: string;
  heading?: string;
  content?: Block[];
  subsections?: { heading: string; content: Block[]; links?: string[] }[];
  link?: LinkRef;
  stats?: Stat[];
  rates?: Rate[];
  rateLabel?: string;
  card?: {
    label?: string;
    badge?: string;
    unit?: string;
    rates?: Rate[];
    footnote?: string;
    chips?: string[];
  };
  ticker?: string[];
  cardLabel?: string;
  badge?: { countUp?: number; value?: string; label?: string };
  metaTitle?: string;
  [key: string]: unknown;
};

const sections = data.sections as Section[];
const meta = sections.find((s) => s.type === "meta");
const hero = sections.find((s) => s.type === "hero");
const faq = sections.find((s) => s.type === "faq");
const contentSecs = sections.filter((s) => s.type === "section");
const budget = contentSecs.find((s) => (s.subsections?.length ?? 0) > 0);
const ctaSec = contentSecs.find((s) => s.content?.some((c) => c.kind === "cta"));
const proseSecs = contentSecs.filter((s) => s !== budget && s !== ctaSec);
const [answer, receipts, why, engagement] = proseSecs;

// Inline CMS: absolute section indices, so data-cms-path stays correct even
// if sections are reordered in the content JSON later.
const heroIdx = hero ? sections.indexOf(hero) : -1;
const answerIdx = answer ? sections.indexOf(answer) : -1;
const receiptsIdx = receipts ? sections.indexOf(receipts) : -1;
const budgetIdx = budget ? sections.indexOf(budget) : -1;
const whyIdx = why ? sections.indexOf(why) : -1;
const engagementIdx = engagement ? sections.indexOf(engagement) : -1;
const faqIdx = faq ? sections.indexOf(faq) : -1;
const ctaIdx = ctaSec ? sections.indexOf(ctaSec) : -1;

const heroParas = hero?.content?.filter((c) => c.kind === "p") ?? [];
const heroCta = hero?.content?.find((c) => c.kind === "cta");
const ctaParas = ctaSec?.content?.filter((c) => c.kind === "p") ?? [];

const faqItems = (faq?.subsections ?? []).map((s, i) => ({
  question: s.heading,
  answer: s.content?.[0]?.text ?? "",
  open: i === 0,
}));

// Split the two-sentence H1: sentence one solid, sentence two hollow (solved vs guessing)
const title = data.title;
const splitAt = title.indexOf(". ");
const titleA = splitAt > -1 ? title.slice(0, splitAt + 1) : title;
const titleB = splitAt > -1 ? title.slice(splitAt + 2) : "";

// Receipts: slice the single proof paragraph into its three client stories, verbatim
const receiptsPara = receipts?.content?.[0]?.text ?? "";
const iOn = receiptsPara.indexOf("onsemi");
const iCT = receiptsPara.indexOf("Country Thunder");
const iCa = receiptsPara.indexOf("Canales");
const receiptsIntro = iOn > -1 ? receiptsPara.slice(0, iOn).trim() : receiptsPara;
const receiptOnsemi = iOn > -1 && iCT > -1 ? receiptsPara.slice(iOn, iCT).trim() : "";
const receiptThunder = iCT > -1 && iCa > -1 ? receiptsPara.slice(iCT, iCa).trim() : "";
const receiptCanales = iCa > -1 ? receiptsPara.slice(iCa).trim() : "";
const receiptsClose = receipts?.content?.[1];

const [whyThesis, whyRates, whyContracts] = why?.content ?? [];
const [engProcess, engCenvar] = engagement?.content ?? [];

// First path-shaped link on a block, e.g. "/platform" out of the links array
const pathOf = (links?: string[]) => links?.find((l) => l.startsWith("/"))?.split(" ")[0];

// Hero side-panel ("product shot"), proof-row stats, and published-facts
// ticker all come from the hero section's JSON now (no page-level literals).
const heroEyebrow = hero?.eyebrow;
const heroLink = hero?.link;
const heroStats = hero?.stats ?? [];
const heroCard = hero?.card;
const rates = heroCard?.rates ?? [];
const tickerItems = hero?.ticker ?? [];

// Sentence one gets the marker treatment: the last word sits on a raspberry block
const taWords = titleA.split(" ");
const taLast = taWords.pop() ?? "";
const taRest = taWords.join(" ");

const navLinks = [
  { label: "Platform", href: "/platform" },
  { label: "Solutions", href: "#" },
  { label: "Pricing", href: "#" },
  { label: "Resources", href: "#" },
];

// Sticky CTA bar copy, from the page JSON
const stickyCta = (data as { stickyCta?: { text?: string; note?: string; cta?: LinkRef } }).stickyCta;

// Chat concierge: prompt labels/links come from the page JSON; answers are the
// FAQ copy verbatim, matched to prompts by order.
type ChatPrompt = { label?: string; href?: string; linkLabel?: string };
const chat = (data as { chat?: { intro?: string; prompts?: ChatPrompt[] } }).chat;
const chatIntro = chat?.intro ?? "";
const chatItems = (faq?.subsections ?? []).map((s, i) => {
  const prompt = chat?.prompts?.[i];
  return {
    label: prompt?.label ?? s.heading,
    text: s.content?.[0]?.text ?? "",
    ...(prompt?.href ? { href: prompt.href, linkLabel: prompt.linkLabel } : {}),
  };
});

const siteUrl = Astro.site?.href ?? "https://geniusmonkey.com/";
const pageUrl = siteUrl;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}#organization`,
      name: "Genius Monkey",
      url: siteUrl,
      foundingDate: "2009",
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      url: siteUrl,
      name: "Genius Monkey",
      publisher: { "@id": `${siteUrl}#organization` },
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: meta?.metaTitle ?? data.title,
      description: data.seoDescription,
      isPartOf: { "@id": `${siteUrl}#website` },
      about: { "@id": `${siteUrl}#organization` },
    },
    {
      "@type": "FAQPage",
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ],
};
---

<BaseLayout
  title={meta?.metaTitle ?? data.title}
  description={data.seoDescription}
  path="/"
  cmsPage="home"
  cmsSeed={data}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <script is:inline>document.documentElement.classList.add("js");</script>
  <Navbar theme="light" links={navLinks} cta={{ label: "Request a demo", href: "#demo" }} />

  <main id="main-content">
  <!-- Hero: light, product-forward. Graph-paper field, marker-highlighted headline,
       floating published-rates card as the "product shot". -->
  <section id="hero" class="relative isolate flex flex-col overflow-hidden bg-white text-ink">
    <!-- Graph paper -->
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 bg-[linear-gradient(rgb(16_19_26/0.045)_1px,transparent_1px),linear-gradient(90deg,rgb(16_19_26/0.045)_1px,transparent_1px)] bg-[size:56px_56px] [mask-image:radial-gradient(ellipse_at_60%_35%,black_35%,transparent_78%)]"
    >
    </div>

    <div
      class="relative z-10 mx-auto grid w-full max-w-7xl grow content-center gap-14 px-6 py-16 md:py-20 lg:min-h-[calc(100dvh-9.5rem)] lg:grid-cols-[1.25fr_1fr] lg:items-center lg:gap-10 lg:px-20"
    >
      <div>
        <p class="gm-eyebrow rise text-slate" data-cms-path={`sections.${heroIdx}.eyebrow`}>{heroEyebrow}</p>

        <h1 class="mt-7 font-display font-extrabold tracking-tight">
          <span class="mask block">
            <span class="line-up block text-[clamp(2.9rem,6.5vw,5.75rem)] leading-[0.98]">
              {taRest}{taRest && " "}
              <span class="gm-marker">
                {taLast.endsWith(".") ? taLast.slice(0, -1) : taLast}</span>{taLast.endsWith(".") ? "." : ""}
            </span>
          </span>
          {
            titleB && (
              <span class="mask mt-4 block">
                <span
                  class="line-up block font-display text-[clamp(1.6rem,3.4vw,3rem)] leading-[1.05] font-extrabold tracking-tight text-slate/60"
                  style="animation-delay: 140ms"
                >
                  {titleB}
                </span>
              </span>
            )
          }
        </h1>

        <p
          class="rise mt-8 max-w-xl text-lead text-slate"
          style="animation-delay: 380ms"
          data-cms-path={`sections.${heroIdx}.content.0.text`}
        >
          {heroParas[0]?.text}
        </p>

        <div class="rise mt-9 flex flex-wrap items-center gap-x-8 gap-y-5" style="animation-delay: 480ms">
          {heroCta && (
            <Button id="hero-cta" size="lg" href={heroCta.href ?? "#demo"} icon="arrow-right">
              <span data-cms-path={`sections.${heroIdx}.content.1.text`}>{heroCta.text}</span>
            </Button>
          )}
          {heroLink && (
            <TextLink href={heroLink.href}>
              <span data-cms-path={`sections.${heroIdx}.link.text`}>{heroLink.text}</span>
            </TextLink>
          )}
        </div>

        <!-- Proof row, from the case studies on this page -->
        <dl class="rise mt-12 grid max-w-xl grid-cols-3 gap-6 border-t border-line pt-6" style="animation-delay: 580ms">
          {
            heroStats.map((stat, i) => (
              <div>
                <dd
                  class="font-display text-2xl font-extrabold tracking-tighter md:text-3xl"
                  data-cms-path={`sections.${heroIdx}.stats.${i}.value`}
                >
                  {stat.value}
                </dd>
                <dt
                  class="mt-1 text-caption font-normal text-slate"
                  data-cms-path={`sections.${heroIdx}.stats.${i}.label`}
                >
                  {stat.label}
                </dt>
              </div>
            ))
          }
        </dl>
      </div>

      <!-- The product shot: published rates as a live card -->
      <div class="rise relative mx-auto w-full max-w-sm lg:mx-0 lg:justify-self-end" style="animation-delay: 300ms">
        <div class="gm-float relative z-10 border border-line bg-white p-6 pb-11 shadow-card md:p-7 md:pb-12">
          <div class="flex items-center justify-between gap-4">
            <p class="gm-label text-[10px] text-slate" data-cms-path={`sections.${heroIdx}.card.label`}>{heroCard?.label}</p>
            <span class="inline-flex items-center gap-1.5 bg-mint-100 px-2.5 py-1 gm-label text-[9px] text-success">
              <span class="relative flex size-1.5">
                <span class="absolute inline-flex size-full animate-ping rounded-full bg-success opacity-60"></span>
                <span class="relative inline-flex size-1.5 rounded-full bg-success"></span>
              </span>
              <span data-cms-path={`sections.${heroIdx}.card.badge`}>{heroCard?.badge}</span>
            </span>
          </div>
          <ul class="mt-5 divide-y divide-line">
            {
              rates.map((rate, i) => (
                <li class="flex items-baseline justify-between gap-4 py-3.5">
                  <span class="text-body font-medium" data-cms-path={`sections.${heroIdx}.card.rates.${i}.channel`}>
                    {rate.channel}
                  </span>
                  <span class="font-display text-xl font-extrabold tracking-tighter md:text-2xl">
                    <span data-cms-path={`sections.${heroIdx}.card.rates.${i}.value`}>{rate.value}</span>
                    <span
                      class="ml-1 text-caption font-normal tracking-normal text-mist"
                      data-cms-path={`sections.${heroIdx}.card.unit`}
                    >
                      {heroCard?.unit}
                    </span>
                  </span>
                </li>
              ))
            }
          </ul>
          <p
            class="mt-4 border-t border-line pt-4 text-caption font-normal text-slate"
            data-cms-path={`sections.${heroIdx}.card.footnote`}
          >
            {heroCard?.footnote}
          </p>
        </div>

        <!-- Floating chips, the two facts buyers ask about first -->
        <div class="gm-float absolute -top-5 -right-3 z-20 flex items-center gap-2 border border-line bg-white py-2 pr-4 pl-2 shadow-card md:-right-8" style="animation-delay: 1.2s">
          <span class="grid size-7 place-items-center bg-raspberry text-white"><Icon name="check" size={14} /></span>
          <span class="gm-label text-[9px]" data-cms-path={`sections.${heroIdx}.card.chips.0`}>{heroCard?.chips?.[0]}</span>
        </div>
        <div class="gm-float absolute -bottom-5 -left-3 z-20 flex items-center gap-2 border border-line bg-white py-2 pr-4 pl-2 shadow-card md:-left-8" style="animation-delay: 2.1s">
          <span class="grid size-7 place-items-center bg-hole text-white"><Icon name="user" size={14} /></span>
          <span class="gm-label text-[9px]" data-cms-path={`sections.${heroIdx}.card.chips.1`}>{heroCard?.chips?.[1]}</span>
        </div>
        <!-- Offset raspberry plate behind the card -->
        <div aria-hidden="true" class="absolute inset-0 z-0 translate-x-3 translate-y-3 bg-raspberry"></div>
      </div>
    </div>

    <!-- Published-facts ticker -->
    <div class="relative overflow-hidden border-t border-line bg-cloud">
      <div class="ticker flex w-max">
        {
          [0, 1].map((dup) => (
            <ul class="flex shrink-0 items-center py-4" aria-hidden={dup === 1 ? "true" : undefined}>
              {tickerItems.map((item, i) => (
                <li class="flex items-center">
                  <span class="gm-label text-[10px] whitespace-nowrap text-slate" data-cms-path={`sections.${heroIdx}.ticker.${i}`}>
                    {item}
                  </span>
                  <span class="mx-10 size-1 shrink-0 rounded-full bg-raspberry/80" />
                </li>
              ))}
            </ul>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Answer block -->
  {
    answer && (
      <section class="bg-white">
        <div class="mx-auto grid max-w-7xl gap-10 px-6 py-16 md:py-24 lg:grid-cols-[1fr_2fr] lg:px-20">
          <div data-reveal>
            <p class="gm-eyebrow text-slate" data-cms-path={`sections.${answerIdx}.eyebrow`}>{answer.eyebrow}</p>
            <h2 class="mt-4 text-h2 tracking-tight text-balance" data-cms-path={`sections.${answerIdx}.heading`}>
              {answer.heading}
            </h2>
          </div>
          <div class="lg:pt-12" data-reveal style="transition-delay: 90ms">
            <div class="border-l-4 border-raspberry pl-6">
              <p class="text-lead text-ink" data-cms-path={`sections.${answerIdx}.content.0.text`}>
                {answer.content?.[0]?.text}
              </p>
            </div>
            <p class="mt-6 text-body text-slate">
              <span data-cms-path={`sections.${answerIdx}.content.1.text`}>{answer.content?.[1]?.text}</span>
              {answer.link && (
                <TextLink href={answer.link.href} class="ml-2">
                  <span data-cms-path={`sections.${answerIdx}.link.text`}>{answer.link.text}</span>
                </TextLink>
              )}
            </p>
          </div>
        </div>
      </section>
    )
  }

  <!-- Receipts -->
  {
    receipts && (
      <section id="receipts" class="bg-ink text-white">
        <div class="mx-auto max-w-7xl px-6 py-20 md:py-28 lg:px-20">
          <div data-reveal>
            <p class="gm-eyebrow text-white/60" data-cms-path={`sections.${receiptsIdx}.eyebrow`}>{receipts.eyebrow}</p>
            <h2 class="mt-4 text-h2 tracking-tight" data-cms-path={`sections.${receiptsIdx}.heading`}>{receipts.heading}</h2>
            <!-- receiptsIntro is a client-side slice of the shared stats.0.content paragraph
                 (see receiptOnsemi/receiptThunder/receiptCanales below); bound here as the
                 representative node for that field, per the CMS spec's derived-text handling. -->
            <p class="mt-5 max-w-xl text-lead text-white/70" data-cms-path={`sections.${receiptsIdx}.content.0.text`}>
              {receiptsIntro}
            </p>
          </div>

          <div class="mt-12 grid border-y border-white/12 lg:grid-cols-3 lg:divide-x lg:divide-white/12">
            <div class="flex flex-col items-start gap-5 border-b border-white/12 py-10 lg:border-b-0 lg:pr-10" data-reveal>
              <p class="gm-label text-[10px] text-white/50" data-cms-path={`sections.${receiptsIdx}.stats.0.label`}>
                {receipts.stats?.[0]?.label}
              </p>
              <p class="font-display leading-[0.95] font-extrabold tracking-tighter">
                <span
                  class="block text-[clamp(1.9rem,3vw,2.5rem)] text-white/30 line-through decoration-raspberry decoration-3"
                  data-cms-path={`sections.${receiptsIdx}.stats.0.before`}
                >
                  {receipts.stats?.[0]?.before}
                </span>
                <span class="block text-[clamp(3.25rem,5.5vw,4.75rem)] text-raspberry" data-cms-path={`sections.${receiptsIdx}.stats.0.value`}>
                  {receipts.stats?.[0]?.value}
                </span>
              </p>
              <p class="inline-block bg-raspberry px-3 py-1.5 gm-label text-[10px]" data-cms-path={`sections.${receiptsIdx}.stats.0.tag`}>
                {receipts.stats?.[0]?.tag}
              </p>
              <p class="max-w-sm text-body text-white/70">{receiptOnsemi}</p>
            </div>

            <div class="flex flex-col items-start gap-5 border-b border-white/12 py-10 lg:border-b-0 lg:px-10" data-reveal style="transition-delay: 90ms">
              <p class="gm-label text-[10px] text-white/50" data-cms-path={`sections.${receiptsIdx}.stats.1.label`}>
                {receipts.stats?.[1]?.label}
              </p>
              <p class="font-display leading-[0.95] font-extrabold tracking-tighter">
                <span class="block text-[clamp(1.9rem,3vw,2.5rem)] text-white/30" data-cms-path={`sections.${receiptsIdx}.stats.1.before`}>
                  {receipts.stats?.[1]?.before}
                </span>
                <span class="block text-[clamp(3.25rem,5.5vw,4.75rem)] text-raspberry">
                  <span data-cms-path={`sections.${receiptsIdx}.stats.1.valuePrefix`}>{receipts.stats?.[1]?.valuePrefix}</span><span data-countup data-target={receipts.stats?.[1]?.countUp}>{receipts.stats?.[1]?.countUp}</span><span data-cms-path={`sections.${receiptsIdx}.stats.1.valueSuffix`}>{receipts.stats?.[1]?.valueSuffix}</span>
                </span>
              </p>
              <p class="inline-block bg-raspberry px-3 py-1.5 gm-label text-[10px]" data-cms-path={`sections.${receiptsIdx}.stats.1.tag`}>
                {receipts.stats?.[1]?.tag}
              </p>
              <p class="max-w-sm text-body text-white/70">{receiptThunder}</p>
            </div>

            <div class="flex flex-col items-start gap-5 py-10 lg:pl-10" data-reveal style="transition-delay: 180ms">
              <p class="gm-label text-[10px] text-white/50" data-cms-path={`sections.${receiptsIdx}.stats.2.label`}>
                {receipts.stats?.[2]?.label}
              </p>
              <p class="font-display leading-[0.95] font-extrabold tracking-tighter">
                <span class="block text-[clamp(1.9rem,3vw,2.5rem)] text-white/30" data-cms-path={`sections.${receiptsIdx}.stats.2.before`}>
                  {receipts.stats?.[2]?.before}
                </span>
                <span class="block text-[clamp(3.25rem,5.5vw,4.75rem)] text-raspberry">
                  <span data-cms-path={`sections.${receiptsIdx}.stats.2.valuePrefix`}>{receipts.stats?.[2]?.valuePrefix}</span><span data-countup data-target={receipts.stats?.[2]?.countUp}>{receipts.stats?.[2]?.countUp}</span><span data-cms-path={`sections.${receiptsIdx}.stats.2.valueSuffix`}>{receipts.stats?.[2]?.valueSuffix}</span>
                </span>
              </p>
              <p class="inline-block bg-raspberry px-3 py-1.5 gm-label text-[10px]" data-cms-path={`sections.${receiptsIdx}.stats.2.tag`}>
                {receipts.stats?.[2]?.tag}
              </p>
              <p class="max-w-sm text-body text-white/70">{receiptCanales}</p>
            </div>
          </div>

          {receiptsClose && (
            <div class="mt-10 flex flex-wrap items-center gap-x-3 gap-y-4" data-reveal>
              <p class="text-lead text-white/80" data-cms-path={`sections.${receiptsIdx}.content.1.text`}>{receiptsClose.text}</p>
              {receipts.link && (
                <TextLink href={receipts.link.href} arrow class="text-white hover:text-white/70">
                  <span data-cms-path={`sections.${receiptsIdx}.link.text`}>{receipts.link.text}</span>
                </TextLink>
              )}
            </div>
          )}
        </div>
      </section>
    )
  }

  <!-- Where to point your budget -->
  {
    budget && (
      <section class="bg-cloud">
        <div class="mx-auto max-w-7xl px-6 py-16 md:py-24 lg:px-20">
          <div data-reveal>
            <p class="gm-eyebrow text-slate" data-cms-path={`sections.${budgetIdx}.eyebrow`}>{budget.eyebrow}</p>
            <h2 class="mt-4 max-w-xl text-h2 tracking-tight text-balance" data-cms-path={`sections.${budgetIdx}.heading`}>
              {budget.heading}
            </h2>
          </div>
          <div class="mt-12 grid gap-4 md:grid-cols-2">
            {budget.subsections?.map((sub, i) => {
              const href = pathOf(sub.links) ?? "#";
              const anchor = i === 0;
              return anchor ? (
                <a
                  href={href}
                  class="group flex flex-col justify-between gap-12 bg-ink p-8 text-white transition-colors hover:bg-ink-800 md:row-span-2 md:p-10"
                  data-reveal
                >
                  <div>
                    <span class="font-display text-6xl font-extrabold tracking-tighter text-raspberry">01</span>
                    <h3 class="mt-5 text-h3 tracking-tight transition-colors group-hover:text-raspberry">
                      <span data-cms-path={`sections.${budgetIdx}.subsections.${i}.heading`}>{sub.heading}</span>
                    </h3>
                    <p class="mt-5 max-w-md text-body text-white/65" data-cms-path={`sections.${budgetIdx}.subsections.${i}.content.0.text`}>
                      {sub.content?.[0]?.text}
                    </p>
                  </div>
                  <span class="grid size-10 shrink-0 place-items-center self-end rounded-full border-2 border-white/30 text-white transition-all group-hover:border-raspberry group-hover:bg-raspberry">
                    <Icon name="arrow-right" size={16} />
                  </span>
                </a>
              ) : (
                <a
                  href={href}
                  class="group flex flex-col border border-line bg-white p-8 transition-colors hover:border-ink"
                  data-reveal
                  style={`transition-delay: ${i * 70}ms`}
                >
                  <span class="gm-label text-[10px] text-raspberry">{String(i + 1).padStart(2, "0")}</span>
