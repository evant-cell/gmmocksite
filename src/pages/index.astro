---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";
import Button from "../components/ui/Button.astro";
import TextLink from "../components/ui/TextLink.astro";
import Icon from "../components/ui/Icon.astro";
import FAQAccordion from "../components/blocks/FAQAccordion.astro";

const page = await getEntry("pages", "home");
if (!page) throw new Error("Missing content: src/content/pages/home.json");
const data = page.data;

type Block = { kind: string; text?: string; links?: string[] };
type Section = {
  type: string;
  heading?: string;
  content?: Block[];
  subsections?: { heading: string; content: Block[]; links?: string[] }[];
  metaTitle?: string;
  [key: string]: unknown;
};

const sections = data.sections as Section[];
const meta = sections.find((s) => s.type === "meta");
const hero = sections.find((s) => s.type === "hero");
const faq = sections.find((s) => s.type === "faq");
const contentSecs = sections.filter((s) => s.type === "section");
const budget = contentSecs.find((s) => (s.subsections?.length ?? 0) > 0);
const ctaSec = contentSecs.find((s) => s.content?.some((c) => c.kind === "cta"));
const proseSecs = contentSecs.filter((s) => s !== budget && s !== ctaSec);
const [answer, receipts, why, engagement] = proseSecs;

const heroParas = hero?.content?.filter((c) => c.kind === "p") ?? [];
const heroCta = hero?.content?.find((c) => c.kind === "cta");
const ctaParas = ctaSec?.content?.filter((c) => c.kind === "p") ?? [];
const ctaBtn = ctaSec?.content?.find((c) => c.kind === "cta");

const faqItems = (faq?.subsections ?? []).map((s, i) => ({
  question: s.heading,
  answer: s.content?.[0]?.text ?? "",
  open: i === 0,
}));

// Split the two-sentence H1: sentence one solid, sentence two hollow (solved vs guessing)
const title = data.title;
const splitAt = title.indexOf(". ");
const titleA = splitAt > -1 ? title.slice(0, splitAt + 1) : title;
const titleB = splitAt > -1 ? title.slice(splitAt + 2) : "";

// Receipts: slice the single proof paragraph into its three client stories, verbatim
const receiptsPara = receipts?.content?.[0]?.text ?? "";
const iOn = receiptsPara.indexOf("onsemi");
const iCT = receiptsPara.indexOf("Country Thunder");
const iCa = receiptsPara.indexOf("Canales");
const receiptsIntro = iOn > -1 ? receiptsPara.slice(0, iOn).trim() : receiptsPara;
const receiptOnsemi = iOn > -1 && iCT > -1 ? receiptsPara.slice(iOn, iCT).trim() : "";
const receiptThunder = iCT > -1 && iCa > -1 ? receiptsPara.slice(iCT, iCa).trim() : "";
const receiptCanales = iCa > -1 ? receiptsPara.slice(iCa).trim() : "";
const receiptsClose = receipts?.content?.[1];

const [whyThesis, whyRates, whyContracts] = why?.content ?? [];
const [engProcess, engCenvar] = engagement?.content ?? [];

// First path-shaped link on a block, e.g. "/platform" out of the links array
const pathOf = (links?: string[]) => links?.find((l) => l.startsWith("/"))?.split(" ")[0];

// Published effective rates, from the differentiator copy on this page
const rates = [
  { channel: "Display", value: "$2-$4" },
  { channel: "Video", value: "$10-$22" },
  { channel: "OTT/CTV", value: "$25-$40" },
];

// Every ticker item is a fact stated in this page's copy
const tickerItems = [
  "Our own DSP",
  "A real expert behind every account",
  "Display $2-$4 CPM",
  "Video $10-$22 CPM",
  "OTT/CTV $25-$40 CPM",
  "No long-term contracts",
  "27 published case studies",
  "Founded in 2009",
];

// Sentence two ends on "guessing." which gets the perpetual scramble treatment
const tbWords = titleB.split(" ");
const tbLast = tbWords.pop() ?? "";
const tbRest = tbWords.join(" ");

const navLinks = [
  { label: "Platform", href: "/platform" },
  { label: "Solutions", href: "#" },
  { label: "Pricing", href: "#" },
  { label: "Resources", href: "#" },
];

const siteUrl = Astro.site?.href ?? "https://geniusmonkey.com/";
const pageUrl = siteUrl;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}#organization`,
      name: "Genius Monkey",
      url: siteUrl,
      foundingDate: "2009",
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      url: siteUrl,
      name: "Genius Monkey",
      publisher: { "@id": `${siteUrl}#organization` },
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: meta?.metaTitle ?? data.title,
      description: data.seoDescription,
      isPartOf: { "@id": `${siteUrl}#website` },
      about: { "@id": `${siteUrl}#organization` },
    },
    {
      "@type": "FAQPage",
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ],
};
---

<BaseLayout title={meta?.metaTitle ?? data.title} description={data.seoDescription} path="/">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <script is:inline>document.documentElement.classList.add("js");</script>
  <Navbar links={navLinks} class="bg-hole!" />

  <!-- Hero -->
  <section id="hero" class="relative isolate flex flex-col overflow-hidden bg-hole text-white">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 bg-[repeating-linear-gradient(90deg,rgb(255_255_255/0.03)_0_1px,transparent_1px_160px)]"
    >
    </div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_80%_-15%,rgb(247_0_78/0.2),transparent_55%)]"
    >
    </div>
    <!-- The bidstream: a live auction network, won bids fire in raspberry -->
    <canvas id="bidnet" class="pointer-events-none absolute inset-0 size-full" aria-hidden="true"></canvas>

    <div
      class="relative z-10 mx-auto flex min-h-[calc(100dvh-9.5rem)] w-full max-w-7xl grow flex-col justify-center px-6 py-16 lg:px-20"
    >
      <p class="gm-label rise text-raspberry">Programmatic Advertising</p>

      <h1 class="mt-7 font-display font-extrabold tracking-tight">
        <span class="mask block">
          <span class="line-up block text-[clamp(3.1rem,8.75vw,8rem)] leading-[0.94]">
            {titleA.endsWith(".") ? <>{titleA.slice(0, -1)}<span class="text-raspberry">.</span></> : titleA}
          </span>
        </span>
        {
          titleB && (
            <span class="mask mt-4 block">
              <span
                class="line-up block text-[clamp(1.9rem,5vw,4.25rem)] leading-[1.02] text-white/45"
                style="animation-delay: 160ms"
              >
                {tbRest} <span data-scramble>{tbLast}</span>
              </span>
            </span>
          )
        }
      </h1>

      <div class="mt-12 grid gap-10 md:mt-16 lg:grid-cols-[minmax(0,36rem)_1fr]">
        <p class="rise text-lead text-white/70" style="animation-delay: 420ms">{heroParas[0]?.text}</p>
        <div class="rise flex flex-wrap items-center gap-x-8 gap-y-5 self-start lg:justify-end" style="animation-delay: 520ms">
          {heroCta && <Button id="hero-cta" size="lg" href="/request-a-demo" icon="arrow-right">{heroCta.text}</Button>}
          <TextLink href="#receipts" class="text-white hover:text-white/70">See the receipts</TextLink>
        </div>
      </div>

    </div>

    <!-- Published-rates ticker -->
    <div class="relative overflow-hidden border-t border-white/10">
      <div class="ticker flex w-max">
        {
          [0, 1].map((dup) => (
            <ul class="flex shrink-0 items-center py-4" aria-hidden={dup === 1 ? "true" : undefined}>
              {tickerItems.map((item) => (
                <li class="flex items-center">
                  <span class="gm-label text-[10px] whitespace-nowrap text-white/55">{item}</span>
                  <span class="mx-10 size-1 shrink-0 rounded-full bg-raspberry/80" />
                </li>
              ))}
            </ul>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Answer block -->
  {
    answer && (
      <section class="bg-white">
        <div class="mx-auto grid max-w-7xl gap-10 px-6 py-16 md:py-24 lg:grid-cols-[1fr_2fr] lg:px-20">
          <div data-reveal>
            <p class="gm-label text-slate">01 / What we do</p>
            <h2 class="mt-4 text-h2 tracking-tight text-balance">{answer.heading}</h2>
          </div>
          <div class="lg:pt-12" data-reveal style="transition-delay: 90ms">
            <div class="border-l-4 border-raspberry pl-6">
              <p class="text-lead text-ink">{answer.content?.[0]?.text}</p>
            </div>
            <p class="mt-6 text-body text-slate">
              {answer.content?.[1]?.text}
              {pathOf(answer.content?.[1]?.links) && (
                <TextLink href={pathOf(answer.content?.[1]?.links)!} class="ml-2">About Genius Monkey</TextLink>
              )}
            </p>
          </div>
        </div>
      </section>
    )
  }

  <!-- Receipts -->
  {
    receipts && (
      <section id="receipts" class="bg-ink text-white">
        <div class="mx-auto max-w-7xl px-6 py-20 md:py-28 lg:px-20">
          <div data-reveal>
            <p class="gm-label text-white/60">02 / Proof</p>
            <h2 class="mt-4 text-h2 tracking-tight">{receipts.heading}</h2>
            <p class="mt-5 max-w-xl text-lead text-white/70">{receiptsIntro}</p>
          </div>

          <div class="mt-12 grid border-y border-white/12 lg:grid-cols-3 lg:divide-x lg:divide-white/12">
            <div class="flex flex-col items-start gap-5 border-b border-white/12 py-10 lg:border-b-0 lg:pr-10" data-reveal>
              <p class="gm-label text-[10px] text-white/50">onsemi</p>
              <p class="font-display leading-[0.95] font-extrabold tracking-tighter">
                <span class="block text-[clamp(1.9rem,3vw,2.5rem)] text-white/30 line-through decoration-raspberry decoration-3">
                  $2,000
                </span>
                <span class="block text-[clamp(3.25rem,5.5vw,4.75rem)] text-raspberry">under $1</span>
              </p>
              <p class="inline-block bg-raspberry px-3 py-1.5 gm-label text-[10px]">Cost per conversion</p>
              <p class="max-w-sm text-body text-white/70">{receiptOnsemi}</p>
            </div>

            <div class="flex flex-col items-start gap-5 border-b border-white/12 py-10 lg:border-b-0 lg:px-10" data-reveal style="transition-delay: 90ms">
              <p class="gm-label text-[10px] text-white/50">Country Thunder</p>
              <p class="font-display leading-[0.95] font-extrabold tracking-tighter">
                <span class="block text-[clamp(1.9rem,3vw,2.5rem)] text-white/30">$1 in</span>
                <span class="block text-[clamp(3.25rem,5.5vw,4.75rem)] text-raspberry">
                  $<span data-countup data-target="230">230</span> back
                </span>
              </p>
              <p class="inline-block bg-raspberry px-3 py-1.5 gm-label text-[10px]">Ticket sales</p>
              <p class="max-w-sm text-body text-white/70">{receiptThunder}</p>
            </div>

            <div class="flex flex-col items-start gap-5 py-10 lg:pl-10" data-reveal style="transition-delay: 180ms">
              <p class="gm-label text-[10px] text-white/50">Canales Furniture</p>
              <p class="font-display leading-[0.95] font-extrabold tracking-tighter">
                <span class="block text-[clamp(1.9rem,3vw,2.5rem)] text-white/30">Since 2018</span>
                <span class="block text-[clamp(3.25rem,5.5vw,4.75rem)] text-raspberry">
                  +<span data-countup data-target="887">887</span>%
                </span>
              </p>
              <p class="inline-block bg-raspberry px-3 py-1.5 gm-label text-[10px]">New website visitors</p>
              <p class="max-w-sm text-body text-white/70">{receiptCanales}</p>
            </div>
          </div>

          {receiptsClose && (
            <div class="mt-10 flex flex-wrap items-center gap-x-3 gap-y-4" data-reveal>
              <p class="text-lead text-white/80">{receiptsClose.text}</p>
              {pathOf(receiptsClose.links) && (
                <TextLink href={pathOf(receiptsClose.links)!} arrow class="text-white hover:text-white/70">
                  Read the case studies
                </TextLink>
              )}
            </div>
          )}
        </div>
      </section>
    )
  }

  <!-- Where to point your budget -->
  {
    budget && (
      <section class="bg-cloud">
        <div class="mx-auto max-w-7xl px-6 py-16 md:py-24 lg:px-20">
          <div data-reveal>
            <p class="gm-label text-slate">03 / Solutions</p>
            <h2 class="mt-4 max-w-xl text-h2 tracking-tight text-balance">{budget.heading}</h2>
          </div>
          <div class="mt-12 grid gap-4 md:grid-cols-2">
            {budget.subsections?.map((sub, i) => {
              const href = pathOf(sub.links) ?? "#";
              const anchor = i === 0;
              return anchor ? (
                <a
                  href={href}
                  class="group flex flex-col justify-between gap-12 bg-ink p-8 text-white transition-colors hover:bg-ink-800 md:row-span-2 md:p-10"
                  data-reveal
                >
                  <div>
                    <span class="font-display text-6xl font-extrabold tracking-tighter text-raspberry">01</span>
                    <h3 class="mt-5 text-h3 tracking-tight transition-colors group-hover:text-raspberry">
                      {sub.heading}
                    </h3>
                    <p class="mt-5 max-w-md text-body text-white/65">{sub.content?.[0]?.text}</p>
                  </div>
                  <span class="grid size-10 shrink-0 place-items-center self-end rounded-full border-2 border-white/30 text-white transition-all group-hover:border-raspberry group-hover:bg-raspberry">
                    <Icon name="arrow-right" size={16} />
                  </span>
                </a>
              ) : (
                <a
                  href={href}
                  class="group flex flex-col border border-line bg-white p-8 transition-colors hover:border-ink"
                  data-reveal
                  style={`transition-delay: ${i * 70}ms`}
                >
                  <span class="gm-label text-[10px] text-raspberry">{String(i + 1).padStart(2, "0")}</span>
                  <h3 class="mt-2 text-h4 tracking-tight transition-colors group-hover:text-raspberry">{sub.heading}</h3>
                  <p class="mt-4 grow text-body text-slate">{sub.content?.[0]?.text}</p>
                  <span class="mt-6 grid size-10 shrink-0 place-items-center self-end rounded-full border-2 border-line text-ink transition-all group-hover:border-raspberry group-hover:bg-raspberry group-hover:text-white">
                    <Icon name="arrow-right" size={16} />
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )
  }

  <!-- Why Genius Monkey -->
  {
    why && (
      <section class="bg-gradient-dark-raspberry text-white">
        <div class="mx-auto max-w-7xl px-6 py-20 md:py-28 lg:px-20">
          <div data-reveal>
            <p class="gm-label text-white/60">04 / The difference</p>
            <h2 class="mt-4 text-h2 tracking-tight">{why.heading}</h2>
            <p class="mt-8 max-w-3xl font-display text-[clamp(1.75rem,3.8vw,3rem)] leading-[1.1] font-extrabold tracking-tight text-balance">
              {whyThesis?.text}
            </p>
          </div>

          <div class="mt-14 grid border-y border-white/20 sm:grid-cols-3 sm:divide-x sm:divide-white/20" data-reveal>
            {rates.map((rate) => (
              <div class="border-b border-white/20 py-8 sm:border-b-0 sm:px-8 sm:first:pl-0 sm:last:pr-0">
                <p class="gm-label text-[10px] text-white/60">{rate.channel}</p>
                <p class="mt-3 font-display text-[clamp(2.5rem,4.5vw,3.75rem)] leading-none font-extrabold tracking-tighter">
                  {rate.value}
                </p>
                <p class="mt-3 text-caption font-normal text-white/55">Effective CPM</p>
              </div>
            ))}
          </div>

          <div class="mt-10 grid gap-10 lg:grid-cols-2" data-reveal>
            <p class="text-body text-white/80">
              {whyRates?.text}
              {pathOf(whyRates?.links) && (
                <TextLink href={pathOf(whyRates?.links)!} class="ml-2 text-white hover:text-white/70">
                  See published rates
                </TextLink>
              )}
            </p>
            <p class="font-display text-h3 leading-snug tracking-tight lg:pl-10">{whyContracts?.text}</p>
          </div>
        </div>
      </section>
    )
  }

  <!-- How an engagement runs -->
  {
    engagement && (
      <section class="bg-white">
        <div class="mx-auto grid max-w-7xl gap-12 px-6 py-16 md:py-24 lg:grid-cols-[1.2fr_1fr] lg:px-20">
          <div data-reveal>
            <p class="gm-label text-slate">05 / Process</p>
            <h2 class="mt-4 text-h2 tracking-tight text-balance">{engagement.heading}</h2>
            <p class="mt-6 max-w-xl text-lead text-slate">{engProcess?.text}</p>
          </div>
          <div class="flex flex-col justify-between gap-8 border border-line p-8 md:p-10" data-reveal style="transition-delay: 120ms">
            <p class="gm-label text-[10px] text-slate">Cenvar Roofing &amp; Solar</p>
            <div class="grid grid-cols-2 divide-x divide-line">
              <div class="pr-6">
                <p class="font-display text-[clamp(2.75rem,4vw,3.5rem)] leading-none font-extrabold tracking-tighter text-raspberry">
                  +<span data-countup data-target="44">44</span>%
                </p>
                <p class="mt-3 text-caption font-normal text-slate">Website leads, first 45 days</p>
              </div>
              <div class="pl-6">
                <p class="font-display text-[clamp(2.75rem,4vw,3.5rem)] leading-none font-extrabold tracking-tighter">
                  +<span data-countup data-target="30">30</span>%
                </p>
                <p class="mt-3 text-caption font-normal text-slate">Gross billing, a year in</p>
              </div>
            </div>
            <div>
              <p class="text-body text-slate">{engCenvar?.text}</p>
              <TextLink href="/programmatic-case-studies" arrow class="mt-4">Cenvar case study</TextLink>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- FAQ -->
  {
    faq && (
      <section class="bg-cloud">
        <div class="mx-auto max-w-7xl px-6 py-16 md:py-24 lg:px-20">
          <div class="grid gap-10 lg:grid-cols-[1fr_2fr]">
            <div data-reveal>
              <p class="gm-label text-slate">06 / FAQ</p>
              <h2 class="mt-4 text-h2 tracking-tight text-balance">{faq.heading}</h2>
            </div>
            <FAQAccordion items={faqItems} class="lg:mt-2" />
          </div>
        </div>
      </section>
    )
  }

  <!-- Done guessing -->
  {
    ctaSec && (
      <section class="relative overflow-hidden bg-hole text-white">
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_85%_120%,rgb(247_0_78/0.45),transparent_55%)]"
        />
        <p
          aria-hidden="true"
          class="pointer-events-none absolute -right-8 -bottom-16 font-display text-[clamp(10rem,26vw,22rem)] leading-none font-extrabold tracking-tighter text-white/4 select-none"
        >
          GM.
        </p>
        <div class="relative mx-auto max-w-7xl px-6 py-20 md:py-28 lg:px-20">
          <h2 class="max-w-2xl font-display text-[clamp(2.75rem,6.5vw,5.5rem)] leading-[1] font-extrabold tracking-tight" data-reveal>
            {ctaSec.heading}
          </h2>
          <div class="mt-8 grid gap-10 lg:grid-cols-[minmax(0,34rem)_1fr]" data-reveal style="transition-delay: 100ms">
            <p class="text-lead text-white/75">{ctaParas[0]?.text}</p>
            <div class="flex items-start lg:justify-end">
              {ctaBtn && <Button size="lg" href="/request-a-demo" icon="arrow-right">{ctaBtn.text}</Button>}
            </div>
          </div>
        </div>
      </section>
    )
  }

  <Footer />
</BaseLayout>

<style is:global>
  /* Hero load-in */
  @keyframes gm-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
  }
  .rise {
    animation: gm-rise 0.8s cubic-bezier(0.23, 1, 0.32, 1) both;
  }

  /* Masked line reveal: each H1 line slides up from behind its own clip */
  .mask {
    overflow: hidden;
  }
  .line-up {
    transform: translateY(112%);
    animation: gm-line-up 1s cubic-bezier(0.16, 1, 0.3, 1) 0.12s forwards;
  }
  @keyframes gm-line-up {
    to {
      transform: translateY(0);
    }
  }

  /* Published-rates ticker */
  .ticker {
    animation: ticker-scroll 44s linear infinite;
  }
  .ticker:hover {
    animation-play-state: paused;
  }
  @keyframes ticker-scroll {
    to {
      transform: translateX(-50%);
    }
  }

  /* Scroll reveals: only applied when JS is on, so content never hides without it */
  .js [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.7s cubic-bezier(0.23, 1, 0.32, 1),
      transform 0.7s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .js [data-reveal].in {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .rise,
    .ticker {
      animation: none;
    }
    .line-up {
      animation: none;
      transform: none;
    }
    #bidnet {
      display: none;
    }
    .js [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Scroll reveals
  const revealer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("in");
          revealer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.15, rootMargin: "0px 0px -40px 0px" },
  );
  document.querySelectorAll("[data-reveal]").forEach((el) => revealer.observe(el));

  // Count-up stats
  const easeOut = (t: number) => 1 - Math.pow(1 - t, 4);
  const runCount = (el: HTMLElement) => {
    const target = Number(el.dataset.target ?? "0");
    const duration = 1400;
    const start = performance.now();
    const tick = (now: number) => {
      const t = Math.min((now - start) / duration, 1);
      el.textContent = Math.round(easeOut(t) * target).toLocaleString("en-US");
      if (t < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  };
  if (!reduceMotion) {
    const counter = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            runCount(entry.target as HTMLElement);
            counter.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.6 },
    );
    document.querySelectorAll<HTMLElement>("[data-countup]").forEach((el) => counter.observe(el));
  }

  // The bidstream: drifting impression nodes, connections by proximity,
  // and a raspberry pulse every couple of seconds when a bid is won.
  const canvas = document.getElementById("bidnet") as HTMLCanvasElement | null;
  const heroSection = document.getElementById("hero");
  if (canvas && heroSection && !reduceMotion) {
    const ctx = canvas.getContext("2d");
    if (ctx) {
      type Node = { x: number; y: number; vx: number; vy: number; r: number };
      type Pulse = { i: number; t: number };
      let w = 0;
      let h = 0;
      let nodes: Node[] = [];
      let pulses: Pulse[] = [];
      let nextPulse = 900;
      let last = performance.now();
      let running = true;
      const LINK = 130;
      const mouse = { x: -9999, y: -9999 };

      const resize = () => {
        const rect = canvas.getBoundingClientRect();
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        w = rect.width;
        h = rect.height;
        canvas.width = Math.round(w * dpr);
        canvas.height = Math.round(h * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        const count = Math.min(120, Math.round((w * h) / 15000));
        nodes = Array.from({ length: count }, () => ({
          // denser toward the right, away from the headline
          x: w * Math.pow(Math.random(), 0.62),
          y: h * Math.random(),
          vx: (Math.random() - 0.5) * 0.22,
          vy: (Math.random() - 0.5) * 0.22,
          r: 1 + Math.random() * 0.9,
        }));
        pulses = [];
      };

      const frame = (now: number) => {
        if (!running) return;
        const dt = Math.min(now - last, 50);
        last = now;

        nextPulse -= dt;
        if (nextPulse <= 0 && nodes.length) {
          pulses.push({ i: Math.floor(Math.random() * nodes.length), t: 0 });
          nextPulse = 1500 + Math.random() * 1800;
        }
        pulses.forEach((p) => (p.t += dt / 950));
        pulses = pulses.filter((p) => p.t < 1);

        for (const n of nodes) {
          const dx = mouse.x - n.x;
          const dy = mouse.y - n.y;
          const d2 = dx * dx + dy * dy;
          if (d2 < 24000 && d2 > 1) {
            const d = Math.sqrt(d2);
            n.vx += (dx / d) * 0.012;
            n.vy += (dy / d) * 0.012;
          }
          const speed = Math.hypot(n.vx, n.vy);
          if (speed > 0.4) {
            n.vx *= 0.4 / speed;
            n.vy *= 0.4 / speed;
          }
          n.x += n.vx * (dt / 16.7);
          n.y += n.vy * (dt / 16.7);
          if (n.x < -20) n.x = w + 20;
          if (n.x > w + 20) n.x = -20;
          if (n.y < -20) n.y = h + 20;
          if (n.y > h + 20) n.y = -20;
        }

        ctx.clearRect(0, 0, w, h);

        const pulseByNode = new Map(pulses.map((p) => [p.i, p.t]));
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const a = nodes[i];
            const b = nodes[j];
            const dx = a.x - b.x;
            const dy = a.y - b.y;
            const d2 = dx * dx + dy * dy;
            if (d2 > LINK * LINK) continue;
            const d = Math.sqrt(d2);
            const pt = pulseByNode.get(i) ?? pulseByNode.get(j);
            if (pt !== undefined) {
              ctx.strokeStyle = `rgb(247 0 78 / ${(1 - d / LINK) * (1 - pt) * 0.55})`;
            } else {
              ctx.strokeStyle = `rgb(255 255 255 / ${(1 - d / LINK) * 0.08})`;
            }
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }

        for (let i = 0; i < nodes.length; i++) {
          const n = nodes[i];
          const pt = pulseByNode.get(i);
          if (pt !== undefined) {
            ctx.fillStyle = "#f7004e";
            ctx.beginPath();
            ctx.arc(n.x, n.y, n.r + 1.6, 0, Math.PI * 2);
            ctx.fill();
            ctx.strokeStyle = `rgb(247 0 78 / ${(1 - pt) * 0.6})`;
            ctx.beginPath();
            ctx.arc(n.x, n.y, 4 + pt * 46, 0, Math.PI * 2);
            ctx.stroke();
          } else {
            ctx.fillStyle = "rgb(255 255 255 / 0.3)";
            ctx.beginPath();
            ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
            ctx.fill();
          }
        }

        requestAnimationFrame(frame);
      };

      resize();
      window.addEventListener("resize", resize);
      heroSection.addEventListener(
        "pointermove",
        (e) => {
          const rect = canvas.getBoundingClientRect();
          mouse.x = e.clientX - rect.left;
          mouse.y = e.clientY - rect.top;
        },
        { passive: true },
      );
      heroSection.addEventListener("pointerleave", () => {
        mouse.x = -9999;
        mouse.y = -9999;
      });
      document.addEventListener("visibilitychange", () => {
        running = !document.hidden;
        if (running) {
          last = performance.now();
          requestAnimationFrame(frame);
        }
      });
      requestAnimationFrame(frame);
    }
  }

  // "guessing." never settles: decode on load, then a letter misfires every few seconds
  const scrambleEl = document.querySelector<HTMLElement>("[data-scramble]");
  if (scrambleEl && !reduceMotion) {
    const target = scrambleEl.textContent ?? "";
    const glyphs = "abcdefghjkmnopqrstuvwxyz#%?!*$";
    const rand = () => glyphs[Math.floor(Math.random() * glyphs.length)];
    const flickerLoop = () => {
      window.setInterval(() => {
        const i = Math.floor(Math.random() * (target.length - 1));
        const chars = target.split("");
        chars[i] = rand();
        scrambleEl.textContent = chars.join("");
        window.setTimeout(() => {
          scrambleEl.textContent = target;
        }, 150);
      }, 3400);
    };
    window.setTimeout(() => {
      let tick = 0;
      const decode = window.setInterval(() => {
        tick++;
        scrambleEl.textContent = target
          .split("")
          .map((ch, i) => (tick > i * 2 + 4 ? ch : rand()))
          .join("");
        if (tick > target.length * 2 + 4) {
          window.clearInterval(decode);
          scrambleEl.textContent = target;
          flickerLoop();
        }
      }, 40);
    }, 750);
  }

  // Magnetic CTA: the demo button leans toward the cursor
  const cta = document.getElementById("hero-cta");
  if (cta && !reduceMotion && window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
    let tx = 0;
    let ty = 0;
    let cx = 0;
    let cy = 0;
    let raf = 0;
    const tick = () => {
      cx += (tx - cx) * 0.16;
      cy += (ty - cy) * 0.16;
      cta.style.transform = `translate(${cx.toFixed(2)}px, ${cy.toFixed(2)}px)`;
      if (Math.abs(cx - tx) > 0.15 || Math.abs(cy - ty) > 0.15) {
        raf = requestAnimationFrame(tick);
      } else {
        raf = 0;
      }
    };
    window.addEventListener(
      "pointermove",
      (e) => {
        const r = cta.getBoundingClientRect();
        const dx = e.clientX - (r.left + r.width / 2);
        const dy = e.clientY - (r.top + r.height / 2);
        const d = Math.hypot(dx, dy);
        if (d < 150) {
          const pull = (1 - d / 150) * 0.38;
          tx = dx * pull;
          ty = dy * pull;
        } else {
          tx = 0;
          ty = 0;
        }
        if (!raf) raf = requestAnimationFrame(tick);
      },
      { passive: true },
    );
  }
</script>
