<style is:global>
  #sticky-cta.show {
    translate: 0 0;
  }

  /* Hero load-in */
  @keyframes gm-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
  }
  .rise {
    animation: gm-rise 0.8s cubic-bezier(0.23, 1, 0.32, 1) both;
  }

  /* Masked line reveal: each H1 line slides up from behind its own clip */
  .mask {
    overflow: hidden;
  }
  .line-up {
    transform: translateY(112%);
    animation: gm-line-up 1s cubic-bezier(0.16, 1, 0.3, 1) 0.12s forwards;
  }
  @keyframes gm-line-up {
    to {
      transform: translateY(0);
    }
  }

  /* Marker highlight: a raspberry block behind the key word, slightly skewed
     like a hand swipe, revealed left-to-right after the line lands */
  .gm-marker {
    position: relative;
    z-index: 0;
    display: inline-block;
    padding: 0 0.12em;
    color: var(--color-ink);
    animation: gm-marker-ink 0.01s linear 1.15s forwards;
  }
  .gm-marker::before {
    content: "";
    position: absolute;
    inset: 0.04em -0.06em 0.02em;
    z-index: -1;
    background: var(--color-raspberry);
    transform: skew(-4deg) rotate(-1.2deg) scaleX(0);
    transform-origin: left center;
    animation: gm-marker-sweep 0.55s cubic-bezier(0.65, 0, 0.35, 1) 0.9s forwards;
  }
  @keyframes gm-marker-sweep {
    to {
      transform: skew(-4deg) rotate(-1.2deg) scaleX(1);
    }
  }
  @keyframes gm-marker-ink {
    to {
      color: #fff;
    }
  }

  /* Floating cards bob gently, out of phase */
  @keyframes gm-bob {
    50% {
      transform: translateY(-8px);
    }
  }
  .gm-float {
    animation: gm-bob 5.5s ease-in-out infinite;
  }

  /* Published-rates ticker */
  .ticker {
    animation: ticker-scroll 44s linear infinite;
  }
  .ticker:hover {
    animation-play-state: paused;
  }
  @keyframes ticker-scroll {
    to {
      transform: translateX(-50%);
    }
  }

  /* Scroll reveals: only applied when JS is on, so content never hides without it */
  .js [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.7s cubic-bezier(0.23, 1, 0.32, 1),
      transform 0.7s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .js [data-reveal].in {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .rise,
    .ticker,
    .gm-float {
      animation: none;
    }
    .gm-marker::before {
      animation: none;
      transform: skew(-4deg) rotate(-1.2deg) scaleX(1);
    }
    .gm-marker {
      color: #fff;
      animation: none;
      transition: none;
    }
    .line-up {
      animation: none;
      transform: none;
    }
    .js [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Scroll reveals
  const revealer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("in");
          revealer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.15, rootMargin: "0px 0px -40px 0px" },
  );
  document.querySelectorAll("[data-reveal]").forEach((el) => revealer.observe(el));

  // Count-up stats
  const easeOut = (t: number) => 1 - Math.pow(1 - t, 4);
  const runCount = (el: HTMLElement) => {
    const target = Number(el.dataset.target ?? "0");
    const duration = 1400;
    const start = performance.now();
    const tick = (now: number) => {
      const t = Math.min((now - start) / duration, 1);
      el.textContent = Math.round(easeOut(t) * target).toLocaleString("en-US");
      if (t < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  };
  if (!reduceMotion) {
    const counter = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            runCount(entry.target as HTMLElement);
            counter.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.6 },
    );
    document.querySelectorAll<HTMLElement>("[data-countup]").forEach((el) => counter.observe(el));
  }

  // Sticky CTA bar: in view after the hero, gone at the demo form, dismissible
  const bar = document.getElementById("sticky-cta");
  const demoSection = document.getElementById("demo");
  const heroForBar = document.getElementById("hero");
  if (bar && demoSection && heroForBar) {
    let pastHero = false;
    let demoOnScreen = false;
    let dismissed = false;
    const update = () => {
      const show = pastHero && !demoOnScreen && !dismissed;
      bar.classList.toggle("show", show);
      if (show) bar.removeAttribute("inert");
      else bar.setAttribute("inert", "");
      document.body.classList.toggle("gm-bar-up", show);
    };
    new IntersectionObserver(([entry]) => {
      pastHero = !entry.isIntersecting;
      update();
    }).observe(heroForBar);
    new IntersectionObserver(([entry]) => {
      demoOnScreen = entry.isIntersecting;
      update();
    }).observe(demoSection);
    document.getElementById("sticky-dismiss")?.addEventListener("click", () => {
      dismissed = true;
      update();
    });
  }

  // #demo links: eased scroll to the closing form, then focus its email field.
  // Hand-rolled instead of CSS smooth scroll so focus timing is deterministic.
  const demoTarget = document.getElementById("demo");
  const scrollToY = (top: number) =>
    new Promise<void>((resolve) => {
      if (reduceMotion) {
        window.scrollTo(0, top);
        resolve();
        return;
      }
      const from = window.scrollY;
      const dist = top - from;
      const duration = Math.min(1100, 350 + Math.abs(dist) * 0.12);
      const t0 = performance.now();
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      const step = (now: number) => {
        const t = Math.min((now - t0) / duration, 1);
        window.scrollTo(0, from + dist * ease(t));
        if (t < 1) requestAnimationFrame(step);
        else resolve();
      };
      requestAnimationFrame(step);
    });
  document.querySelectorAll<HTMLAnchorElement>('a[href="#demo"]').forEach((a) => {
    a.addEventListener("click", (e) => {
      if (!demoTarget) return;
      e.preventDefault();
      history.pushState(null, "", "#demo");
      scrollToY(demoTarget.getBoundingClientRect().top + window.scrollY).then(() => {
        document.getElementById("cta-email")?.focus({ preventScroll: true });
      });
    });
  });

  // Magnetic CTA: the demo button leans toward the cursor
  const cta = document.getElementById("hero-cta");
  if (cta && !reduceMotion && window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
    let tx = 0;
    let ty = 0;
    let cx = 0;
    let cy = 0;
    let raf = 0;
    const tick = () => {
      cx += (tx - cx) * 0.16;
      cy += (ty - cy) * 0.16;
      cta.style.transform = `translate(${cx.toFixed(2)}px, ${cy.toFixed(2)}px)`;
      if (Math.abs(cx - tx) > 0.15 || Math.abs(cy - ty) > 0.15) {
        raf = requestAnimationFrame(tick);
      } else {
        raf = 0;
      }
    };
    window.addEventListener(
      "pointermove",
      (e) => {
        const r = cta.getBoundingClientRect();
        const dx = e.clientX - (r.left + r.width / 2);
        const dy = e.clientY - (r.top + r.height / 2);
        const d = Math.hypot(dx, dy);
        if (d < 150) {
          const pull = (1 - d / 150) * 0.38;
          tx = dx * pull;
          ty = dy * pull;
        } else {
          tx = 0;
          ty = 0;
        }
        if (!raf) raf = requestAnimationFrame(tick);
      },
      { passive: true },
    );
  }
</script>
