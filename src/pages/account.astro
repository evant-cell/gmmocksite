---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";
import Icon from "../components/ui/Icon.astro";

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Platform", href: "/platform" },
];
---

<BaseLayout title="Your account" description="Manage your Genius Monkey account." noindex>
  <script is:inline>document.documentElement.classList.add("js");</script>
  <Navbar theme="light" links={navLinks} />

  <main id="main-content" class="bg-cloud">
    <section class="mx-auto flex min-h-[60vh] max-w-3xl flex-col justify-center px-6 py-20">
      <!-- Auth gate placeholder -->
      <div data-auth-loading class="flex items-center gap-3 text-slate">
        <Icon name="clock" size={20} class="animate-pulse" />
        <p class="text-lead">Checking your session</p>
      </div>

      <!-- Revealed once the visitor is confirmed signed in -->
      <div data-auth-content class="hidden">
        <p class="gm-eyebrow text-slate">Account</p>
        <h1 class="mt-3 text-h1 font-display font-extrabold text-ink">Your account</h1>

        <div class="mt-10 grid gap-px overflow-hidden border border-line bg-line sm:grid-cols-2">
          <div class="bg-white p-6">
            <p class="gm-label text-slate">Signed in as</p>
            <p class="mt-2 font-medium break-all text-ink" data-account-email></p>
          </div>
          <div class="bg-white p-6">
            <p class="gm-label text-slate">Role</p>
            <p class="mt-2 font-medium text-ink capitalize" data-account-role></p>
          </div>
        </div>

        <!-- Admin-only panel, gated by role (reuses the navbar convention) -->
        <div
          data-requires-role="admin"
          class="mt-8 flex items-start gap-4 border-l-4 border-cobalt bg-info-100 px-6 py-5"
        >
          <Icon name="settings" size={20} class="mt-0.5 shrink-0 text-cobalt" />
          <div>
            <p class="font-semibold text-ink">You have admin access</p>
            <p class="mt-1 text-sm text-slate">
              Open the <a href="/admin" class="font-semibold text-cobalt underline underline-offset-2">admin area</a> to manage the site.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  import { guardPage } from "../lib/auth";

  const loading = document.querySelector<HTMLElement>("[data-auth-loading]");
  const content = document.querySelector<HTMLElement>("[data-auth-content]");

  guardPage({}).then(({ user, role }) => {
    document.querySelectorAll<HTMLElement>("[data-account-email]").forEach(
      (el) => (el.textContent = user?.email ?? ""),
    );
    document.querySelectorAll<HTMLElement>("[data-account-role]").forEach(
      (el) => (el.textContent = role ?? "member"),
    );
    document.querySelectorAll<HTMLElement>("[data-requires-role]").forEach((el) => {
      const allowed = (el.getAttribute("data-requires-role") ?? "").split(",").map((s) => s.trim());
      el.classList.toggle("is-visible", !!role && allowed.includes(role));
    });
    loading?.classList.add("hidden");
    content?.classList.remove("hidden");
  });
</script>

<style>
  [data-requires-role] {
    display: none;
  }
  [data-requires-role].is-visible {
    display: flex;
  }
</style>
