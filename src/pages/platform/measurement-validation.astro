  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* Hero load-in */
  @keyframes gm-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
  }
  .rise {
    animation: gm-rise 0.8s cubic-bezier(0.23, 1, 0.32, 1) both;
  }

  /* Masked line reveal */
  .mask {
    overflow: hidden;
  }
  .line-up {
    transform: translateY(112%);
    animation: gm-line-up 1s cubic-bezier(0.16, 1, 0.3, 1) 0.12s forwards;
  }
  @keyframes gm-line-up {
    to {
      transform: translateY(0);
    }
  }

  /* Scroll reveals: only applied when JS is on, so content never hides without it */
  .js [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.7s cubic-bezier(0.23, 1, 0.32, 1),
      transform 0.7s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .js [data-reveal].in {
    opacity: 1;
    transform: none;
  }

  /* Journey timeline. The server renders the distributed state, so no-JS and
     reduced-motion readers get the honest version rather than the last-click one. */
  /* Sized in user units: the figure scales up, so keep these small */
  #journey .axis-label {
    font-family: var(--font-label);
    font-size: 6px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  #journey .credit,
  #journey .touch {
    transition:
      y 0.7s cubic-bezier(0.23, 1, 0.32, 1),
      height 0.7s cubic-bezier(0.23, 1, 0.32, 1),
      fill 0.5s ease,
      stroke 0.5s ease,
      r 0.5s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .rise {
      animation: none;
    }
    .line-up {
      animation: none;
      transform: none;
    }
    .js [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
    #journey .credit,
    #journey .touch {
      transition: none;
    }
  }
</style>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Scroll reveals
  const revealer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("in");
          revealer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.15, rootMargin: "0px 0px -40px 0px" },
  );
  document.querySelectorAll("[data-reveal]").forEach((el) => revealer.observe(el));

  // Count-up stats
  const easeOut = (t: number) => 1 - Math.pow(1 - t, 4);
  const runCount = (el: HTMLElement) => {
    const target = Number(el.dataset.target ?? "0");
    const decimals = Number(el.dataset.decimals ?? "0");
    const duration = 1400;
    const start = performance.now();
    const tick = (now: number) => {
      const t = Math.min((now - start) / duration, 1);
      const value = easeOut(t) * target;
      el.textContent = decimals
        ? value.toFixed(decimals)
        : Math.round(value).toLocaleString("en-US");
      if (t < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  };
  if (!reduceMotion) {
    const counter = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            runCount(entry.target as HTMLElement);
            counter.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.6 },
    );
    document.querySelectorAll<HTMLElement>("[data-countup]").forEach((el) => counter.observe(el));
  }

  // The markup already holds the distributed reading, so no-JS and reduced-motion
  // readers land on the honest version. When motion is welcome the timeline first
  // rewinds to how a last-click report tells it, every point of credit stacked on
  // the final touch, then hands that credit back across the path that earned it.
  const journey = document.getElementById("journey");
  if (journey && !reduceMotion) {
    const bars = Array.from(journey.querySelectorAll<SVGRectElement>(".credit"));
    const touches = Array.from(journey.querySelectorAll<SVGCircleElement>(".touch"));
    const FULL = 62;

    const rewind = () => {
      bars.forEach((bar, i) => {
        const last = bar.dataset.last === "true";
        bar.setAttribute("y", String(last ? 104 - FULL : 104));
        bar.setAttribute("height", String(last ? FULL : 0));
        bar.setAttribute("fill", last ? "#f7004e" : "#3d5afe");
        const touch = touches[i];
        if (touch) {
          touch.setAttribute("fill", last ? "#f7004e" : "#ffffff");
          touch.setAttribute("stroke", last ? "#f7004e" : "#8a91a3");
          touch.setAttribute("r", last ? "7" : "5");
        }
      });
    };

    const distribute = () => {
      bars.forEach((bar, i) => {
        window.setTimeout(() => {
          bar.setAttribute("y", bar.dataset.y ?? "104");
          bar.setAttribute("height", bar.dataset.h ?? "0");
          bar.setAttribute("fill", "#3d5afe");
          const touch = touches[i];
          if (touch) {
            touch.setAttribute("fill", "#3d5afe");
            touch.setAttribute("stroke", "#3d5afe");
            touch.setAttribute("r", "5");
          }
        }, i * 90);
      });
    };

    // Rewind before the figure is on screen so the reader never sees it snap back
    const watcher = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            window.setTimeout(distribute, 900);
            watcher.disconnect();
          }
        }
      },
      { threshold: 0.4 },
    );
    rewind();
    watcher.observe(journey);
  }
</script>
