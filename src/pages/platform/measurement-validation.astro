---
import { getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/blocks/Navbar.astro";
import Footer from "../../components/blocks/Footer.astro";
import Breadcrumbs from "../../components/blocks/Breadcrumbs.astro";
import Button from "../../components/ui/Button.astro";
import TextLink from "../../components/ui/TextLink.astro";
import FAQAccordion from "../../components/blocks/FAQAccordion.astro";

const page = await getEntry("pages", "platform-measurement-validation");
if (!page) throw new Error("Missing content: src/content/pages/platform-measurement-validation.json");
const data = page.data;

type Block = { kind: string; text?: string; links?: string[]; headers?: string[]; rows?: string[][] };
type Section = {
  type: string;
  heading?: string;
  content?: Block[];
  subsections?: { heading: string; content: Block[]; links?: string[] }[];
  metaTitle?: string;
  [key: string]: unknown;
};

const sections = data.sections as Section[];
const meta = sections.find((s) => s.type === "meta");
const hero = sections.find((s) => s.type === "hero");
const faq = sections.find((s) => s.type === "faq");
const contentSecs = sections.filter((s) => s.type === "section");
const metrics = contentSecs.find((s) => (s.subsections?.length ?? 0) > 0);
const ctaSec = contentSecs.find((s) => s.content?.some((c) => c.kind === "cta"));
// Remaining prose sections in JSON order: definition, how it breaks, multi-touch,
// impression tracking, viewability, the 2016 interlude, what changes.
const [definition, problem, multiTouch, impressions, viewability, origin, results] = contentSecs.filter(
  (s) => s !== metrics && s !== ctaSec,
);

const heroParas = hero?.content?.filter((c) => c.kind === "p") ?? [];
const heroCta = hero?.content?.find((c) => c.kind === "cta");
const ctaParas = ctaSec?.content?.filter((c) => c.kind === "p") ?? [];
const ctaBtn = ctaSec?.content?.find((c) => c.kind === "cta");

const faqItems = (faq?.subsections ?? []).map((s, i) => ({
  question: s.heading,
  answer: s.content?.[0]?.text ?? "",
  open: i === 0,
}));
const faqLinks = (faq?.subsections ?? [])
  .map((s) => s.content?.[0]?.links)
  .filter((l): l is string[] => Boolean(l?.length));

const pathOf = (links?: string[]) => links?.find((l) => l.startsWith("/"))?.split(" ")[0];

// H1 accent: the last click gets struck through, which is the whole argument
const title = data.title;
const accentAt = title.indexOf("the last click");
const titleHead = accentAt > -1 ? title.slice(0, accentAt) : title;
const titleAccent = accentAt > -1 ? title.slice(accentAt) : "";

// Split the closing problem paragraph at its own thesis sentence so the sentence
// can carry display weight. The three parts render in source order.
const splitAround = (text: string, anchor: string) => {
  const at = text.indexOf(anchor);
  if (at < 0) return { before: text, hit: "", after: "" };
  return {
    before: text.slice(0, at).trim(),
    hit: anchor,
    after: text.slice(at + anchor.length).trim(),
  };
};
const servedPara = problem?.content?.[3]?.text ?? "";
const served = splitAround(servedPara, "Served is not seen.");
const viewPara = viewability?.content?.[1]?.text ?? "";
const view = splitAround(viewPara, "Served is not seen.");

// The results paragraph ends on the page's thesis. Pull it out as a quote.
const resultsPara = results?.content?.[0]?.text ?? "";
const thesisAt = resultsPara.indexOf("The campaign didn't get better.");
const resultsLead = thesisAt > -1 ? resultsPara.slice(0, thesisAt).trim() : resultsPara;
const resultsThesis = thesisAt > -1 ? resultsPara.slice(thesisAt).trim() : "";

// Every metric in the metrics section, keyed to the accent it carries
const metricAccent: Record<string, string> = {
  MER: "text-cobalt",
  CPM: "text-ink",
  CPA: "text-raspberry",
};

// Journey timeline: seven impressions across a 90 day path. Last-click gives all
// the credit to node seven; multi-touch spreads it. Heights are proportional
// only, no figures are shown.
const nodes = [40, 120, 205, 285, 370, 450, 540];
const credit = [16, 22, 14, 26, 18, 24, 30];

const navLinks = [
  { label: "Platform", href: "/platform" },
  { label: "Solutions", href: "#" },
  { label: "Pricing", href: "#" },
  { label: "Resources", href: "#" },
];

const siblings = [
  { label: "Behavioral targeting", href: "/platform/behavioral-targeting" },
  { label: "The dashboard", href: "/platform/the-dashboard" },
  { label: "The platform", href: "/platform" },
];

const pagePath = (((meta?.url as string) ?? "/platform/measurement-validation") + "/").replace(/\/+$/, "/");
const siteUrl = Astro.site?.href ?? "https://geniusmonkey.com/";
const pageUrl = new URL(pagePath, siteUrl).href;
const platformUrl = new URL("/platform/", siteUrl).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}#organization`,
      name: "Genius Monkey",
      url: siteUrl,
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: meta?.metaTitle ?? data.title,
      description: data.seoDescription,
      isPartOf: { "@id": `${siteUrl}#organization` },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
        { "@type": "ListItem", position: 2, name: "Platform", item: platformUrl },
        { "@type": "ListItem", position: 3, name: "Measurement and validation", item: pageUrl },
      ],
    },
    {
      "@type": "FAQPage",
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ],
};
---

<BaseLayout title={meta?.metaTitle ?? data.title} description={data.seoDescription} path={pagePath}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <script is:inline>document.documentElement.classList.add("js");</script>
  <Navbar links={navLinks} class="bg-hole!" />

  <main id="main-content">
  <!-- Hero -->
  <section class="relative isolate overflow-hidden bg-hole text-white">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_15%_-10%,rgb(61_90_254/0.24),transparent_55%)]"
    >
    </div>
    <!-- The path, with only the finish line lit -->
    <svg
      aria-hidden="true"
      viewBox="0 0 600 60"
      preserveAspectRatio="none"
      class="pointer-events-none absolute inset-x-0 bottom-24 h-24 w-full opacity-70"
    >
      <line x1="0" y1="30" x2="600" y2="30" stroke="#ffffff" stroke-opacity="0.1" stroke-width="1" />
      {
        nodes.map((x, i) => (
          <circle
            cx={x}
            cy="30"
            r={i === nodes.length - 1 ? 7 : 4}
            fill={i === nodes.length - 1 ? "#f7004e" : "#ffffff"}
            fill-opacity={i === nodes.length - 1 ? 0.9 : 0.15}
          />
        ))
      }
    </svg>

    <div class="relative mx-auto max-w-7xl px-6 pt-10 pb-24 md:pb-32 lg:px-20">
      <Breadcrumbs
        theme="dark"
        class="bg-transparent! px-0! py-0!"
        items={[
          { label: "Home", href: "/" },
          { label: "Platform", href: "/platform" },
          { label: "Measurement and validation" },
        ]}
      />
      <p class="gm-label rise mt-10 text-raspberry">The Platform / Measurement &amp; Validation</p>
      <h1 class="mt-6 max-w-5xl font-display font-extrabold tracking-tight">
        <span class="mask block">
          <span class="line-up block text-[clamp(2.5rem,6.5vw,5.5rem)] leading-[0.98]">
            {titleHead}
            {
              titleAccent && (
                <span class="text-white/45 line-through decoration-raspberry decoration-4">{titleAccent}</span>
              )
            }
          </span>
        </span>
      </h1>
      <div class="mt-12 grid gap-10 lg:grid-cols-[minmax(0,36rem)_1fr]">
        <p class="rise text-lead text-white/70" style="animation-delay: 320ms">{heroParas[0]?.text}</p>
        <div class="rise flex items-start lg:justify-end" style="animation-delay: 400ms">
          {heroCta && <Button size="lg" href="/request-a-demo" icon="arrow-right">{heroCta.text}</Button>}
        </div>
      </div>
    </div>
  </section>

  <!-- 01 Definition -->
  {
    definition && (
      <section class="bg-white">
        <div class="mx-auto grid max-w-7xl gap-10 px-6 py-16 md:py-24 lg:grid-cols-[1fr_2fr] lg:px-20">
          <div data-reveal>
            <p class="gm-label text-slate">01 / Definition</p>
            <h2 class="mt-4 text-h2 tracking-tight text-balance">{definition.heading}</h2>
          </div>
          <div class="lg:pt-12" data-reveal style="transition-delay: 90ms">
            <div class="border-l-4 border-raspberry pl-6">
              <p class="text-lead text-ink">{definition.content?.[0]?.text}</p>
            </div>
            <p class="mt-6 text-body text-slate">{definition.content?.[1]?.text}</p>
          </div>
        </div>
      </section>
    )
  }

  <!-- 02 How good advertising gets cancelled -->
  {
    problem && (
      <section class="relative overflow-hidden bg-ink text-white">
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_20%_-10%,rgb(61_90_254/0.25),transparent_55%)]"
        />
        <div class="relative mx-auto max-w-7xl px-6 py-20 md:py-28 lg:px-20">
          <p class="gm-label text-white/60" data-reveal>02 / How It Breaks</p>
          <h2
            class="mt-4 max-w-3xl font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.05] font-extrabold tracking-tight text-balance"
            data-reveal
          >
            {problem.heading}
          </h2>
          <div class="mt-12 flex max-w-2xl flex-col gap-8 lg:ml-[18%]">
            {
              problem.content?.slice(0, 3).map((block, i) => (
                <p class="text-lead text-white/80" data-reveal style={`transition-delay: ${i * 80}ms`}>
                  {block.text}
                </p>
              ))
            }
            {
              served.hit ? (
                <div data-reveal>
                  <p class="text-lead text-white/80">{served.before}</p>
                  <p class="mt-6 font-display text-h3 leading-snug tracking-tight text-white">{served.hit}</p>
                  <p class="mt-6 text-lead text-white/80">{served.after}</p>
                </div>
              ) : (
                <p class="text-lead text-white/80" data-reveal>
                  {servedPara}
                </p>
              )
            }
          </div>
        </div>
      </section>
    )
  }

  <!-- 03 Multi-touch attribution: the whole path, credited -->
  {
    multiTouch && (
      <section class="bg-white">
        <div class="mx-auto max-w-7xl px-6 py-16 md:py-24 lg:px-20">
          <div class="grid gap-10 lg:grid-cols-[1fr_2fr]">
            <div data-reveal>
              <p class="gm-label text-slate">03 / Multi-Touch</p>
              <h2 class="mt-4 text-h2 tracking-tight text-balance">{multiTouch.heading}</h2>
            </div>
            <div class="lg:pt-12" data-reveal style="transition-delay: 90ms">
              <div class="border-l-4 border-cobalt pl-6">
                <p class="text-lead text-ink">{multiTouch.content?.[0]?.text}</p>
              </div>
              <p class="mt-6 max-w-2xl text-body text-slate">
                {multiTouch.content?.[1]?.text}
                {
                  pathOf(multiTouch.content?.[1]?.links) && (
                    <TextLink href={pathOf(multiTouch.content?.[1]?.links)!} class="ml-2">
                      Cross-device identity
                    </TextLink>
                  )
                }
              </p>
            </div>
          </div>

          <!-- The path: seven impressions over 90 days. Credit starts hoarded at
               the finish line and spreads across the path that earned it. -->
          <figure class="mt-16" data-reveal>
            <svg id="journey" viewBox="0 0 600 150" class="w-full" aria-hidden="true">
              <rect x="0" y="18" width="140" height="86" fill="#3d5afe" fill-opacity="0.08" />
              <line x1="0" y1="104" x2="600" y2="104" stroke="#e4e7ef" stroke-width="2" />
              <line x1="140" y1="18" x2="140" y2="112" stroke="#3d5afe" stroke-opacity="0.45" stroke-dasharray="3 3" />
              <line x1="580" y1="94" x2="580" y2="112" stroke="#8a91a3" />
              <text x="146" y="26" class="axis-label" fill="#3d5afe">Day 10</text>
              <text x="580" y="122" class="axis-label" fill="#5b6472" text-anchor="end">Day 90</text>
              <text x="4" y="122" class="axis-label" fill="#8a91a3">The reporting window</text>
              {
                nodes.map((x, i) => {
                  const last = i === nodes.length - 1;
                  // Rendered distributed, which is the honest reading. Script
                  // rewinds to last-click first only when motion is welcome.
                  return (
                    <g>
                      <rect
                        class="credit"
                        x={x - 9}
                        y={104 - credit[i]}
                        width="18"
                        height={credit[i]}
                        data-y={104 - credit[i]}
                        data-h={credit[i]}
                        data-last={last ? "true" : undefined}
                        fill="#3d5afe"
                      />
                      <circle class="touch" cx={x} cy="104" r="5" fill="#3d5afe" stroke="#3d5afe" stroke-width="2" />
                    </g>
                  );
                })
              }
            </svg>
            <figcaption class="mt-4 gm-label text-[10px] text-mist">
              Credit across the path, not only its last step
            </figcaption>
          </figure>

          <!-- Ashley Furniture put a number on the gap -->
          <div class="mt-14 grid items-start gap-10 border-t border-line pt-10 lg:grid-cols-[minmax(0,18rem)_1fr]" data-reveal>
            <div>
              <p class="font-display text-[clamp(3rem,6vw,5rem)] leading-[0.95] font-extrabold tracking-tighter text-raspberry">
                <span data-countup data-target="90">90</span> days
              </p>
              <p class="mt-4 inline-block bg-raspberry px-3 py-1.5 gm-label text-[10px] text-white">
                Time to convert, 40%+ of buyers
              </p>
            </div>
            <div>
              <p class="max-w-2xl text-lead text-slate">{multiTouch.content?.[2]?.text}</p>
              {
                pathOf(multiTouch.content?.[2]?.links) && (
                  <TextLink href={pathOf(multiTouch.content?.[2]?.links)!} arrow class="mt-5">
                    Ashley Furniture case study
                  </TextLink>
                )
              }
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- 04 Impression tracking -->
  {
    impressions && (
      <section class="bg-cloud">
        <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 py-16 md:py-24 lg:grid-cols-2 lg:px-20">
          <div data-reveal>
            <p class="gm-label text-slate">04 / Impression Tracking</p>
            <h2 class="mt-4 max-w-lg text-h2 tracking-tight text-balance">{impressions.heading}</h2>
            <div class="mt-8 flex flex-col gap-6">
              {impressions.content?.map((block) => <p class="max-w-2xl text-lead text-slate">{block.text}</p>)}
            </div>
          </div>
          <!-- Nine impressions, one click, and the three that moved the buyer anyway -->
          <svg aria-hidden="true" viewBox="0 0 300 220" class="w-full" data-reveal style="transition-delay: 90ms">
            {
              Array.from({ length: 9 }, (_, i) => {
                const col = i % 3;
                const row = Math.floor(i / 3);
                const x = 10 + col * 62;
                const y = 10 + row * 48;
                const contributed = [1, 3, 6].includes(i);
                const clicked = i === 4;
                return (
                  <g>
                    <rect
                      x={x}
                      y={y}
                      width="52"
                      height="34"
                      rx="3"
                      fill="none"
                      stroke={contributed || clicked ? "#3d5afe" : "#c9cfdd"}
                      stroke-width={contributed || clicked ? 2 : 1}
                    />
                    {clicked && <circle cx={x + 42} cy={y + 26} r="4" fill="#f7004e" />}
                    {contributed && (
                      <line
                        x1={x + 26}
                        y1={y + 34}
                        x2="196"
                        y2="196"
                        stroke="#3d5afe"
                        stroke-opacity="0.4"
                        stroke-dasharray="4 4"
                      />
                    )}
                  </g>
                );
              })
            }
            <circle cx="196" cy="196" r="16" fill="#3d5afe" />
            <path d="M188 196 l6 6 l11 -12" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" />
          </svg>
        </div>
      </section>
    )
  }

  <!-- 05 Viewability: short, dark, and blunt -->
  {
    viewability && (
      <section class="relative overflow-hidden bg-ink text-white">
        <div class="relative mx-auto max-w-7xl px-6 py-20 md:py-24 lg:px-20">
          <div class="grid items-center gap-12 lg:grid-cols-[1.3fr_1fr]">
            <div data-reveal>
              <p class="gm-label text-white/60">05 / Viewability</p>
              <h2 class="mt-4 text-h2 tracking-tight">{viewability.heading}</h2>
              <p class="mt-8 max-w-2xl text-lead text-white/75">{viewability.content?.[0]?.text}</p>
              {
                view.hit ? (
                  <>
                    <p class="mt-10 font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.02] font-extrabold tracking-tight">
                      Served is not <span class="text-raspberry">seen.</span>
                    </p>
                    <p class="mt-8 max-w-2xl text-lead text-white/75">{view.after}</p>
                  </>
                ) : (
                  <p class="mt-8 max-w-2xl text-lead text-white/75">{viewPara}</p>
                )
              }
            </div>
            <!-- One ad above the fold, one buried below it -->
            <svg aria-hidden="true" viewBox="0 0 260 200" class="w-full" data-reveal style="transition-delay: 90ms">
              <rect x="6" y="6" width="248" height="188" rx="5" fill="none" stroke="#ffffff" stroke-opacity="0.16" />
              <rect x="20" y="24" width="90" height="7" rx="3.5" fill="#ffffff" fill-opacity="0.22" />
              <rect x="20" y="42" width="140" height="5" rx="2.5" fill="#ffffff" fill-opacity="0.1" />
              <rect x="20" y="56" width="120" height="5" rx="2.5" fill="#ffffff" fill-opacity="0.1" />
              <rect x="176" y="24" width="62" height="48" rx="3" fill="none" stroke="#f7004e" stroke-width="2" />
              <line x1="6" y1="112" x2="254" y2="112" stroke="#ffffff" stroke-opacity="0.3" stroke-dasharray="5 5" />
              <rect x="20" y="132" width="100" height="46" rx="3" fill="#ffffff" fill-opacity="0.08" />
              <rect x="140" y="132" width="98" height="10" rx="3" fill="#ffffff" fill-opacity="0.06" />
              <rect x="140" y="150" width="78" height="10" rx="3" fill="#ffffff" fill-opacity="0.06" />
            </svg>
          </div>
        </div>
      </section>
    )
  }

  <!-- 06 The metrics, and where each one misleads -->
  {
    metrics && (
      <section class="bg-cloud">
        <div class="mx-auto max-w-7xl px-6 py-16 md:py-24 lg:px-20">
          <p class="gm-label text-slate" data-reveal>06 / The Metrics</p>
          <h2 class="mt-4 max-w-3xl text-h2 tracking-tight text-balance" data-reveal>{metrics.heading}</h2>
          <p class="mt-6 max-w-2xl text-lead text-slate" data-reveal>{metrics.content?.[0]?.text}</p>

          <div class="mt-12 grid gap-4 md:grid-cols-2">
            {
              metrics.subsections?.map((sub, i) =>
                i === 0 ? (
                  <div class="flex flex-col justify-between gap-10 bg-ink p-8 text-white" data-reveal>
                    <div>
                      <h3 class="font-display text-6xl font-extrabold tracking-tighter text-raspberry">
                        {sub.heading}
                      </h3>
                      <p class="mt-6 max-w-md text-body text-white/70">{sub.content?.[0]?.text}</p>
                    </div>
                    <div>
                      <p class="font-display text-[clamp(3rem,7vw,5.5rem)] leading-[0.95] font-extrabold tracking-tighter text-white">
                        <span data-countup data-target="2300">2300</span>%
                      </p>
                      <p class="mt-4 inline-block bg-raspberry px-3 py-1.5 gm-label text-[10px]">
                        Return on ad spend, whole path
                      </p>
                      {pathOf(sub.links) && (
                        <div class="mt-6">
                          <TextLink href={pathOf(sub.links)!} arrow class="text-white hover:text-white/70">
                            ROAS, defined
                          </TextLink>
                        </div>
                      )}
                    </div>
                  </div>
                ) : (
                  <div
                    class="flex flex-col border border-line bg-white p-8"
                    data-reveal
                    style={`transition-delay: ${i * 70}ms`}
                  >
                    <h3
                      class:list={[
                        "font-display text-6xl font-extrabold tracking-tighter",
                        metricAccent[sub.heading] ?? "text-ink",
                      ]}
                    >
                      {sub.heading}
                    </h3>
                    <p class="mt-5 grow text-body text-slate">{sub.content?.[0]?.text}</p>
                    {pathOf(sub.links) && (
                      <TextLink href={pathOf(sub.links)!} arrow class="mt-6 self-start">
                        {pathOf(sub.links) === "/pricing" ? "Published rates" : `${sub.heading}, defined`}
                      </TextLink>
                    )}
                  </div>
                ),
              )
            }
          </div>
        </div>
      </section>
    )
  }

  <!-- 07 Shipped in 2016 -->
  {
    origin && (
      <section class="relative overflow-hidden bg-white">
        <p
          aria-hidden="true"
          class="pointer-events-none absolute -top-6 right-0 font-display text-[clamp(8rem,20vw,16rem)] leading-none font-extrabold tracking-tighter text-cloud select-none"
        >
          2016
        </p>
        <div class="relative mx-auto max-w-7xl px-6 py-16 md:py-24 lg:px-20">
          <p class="gm-label text-slate" data-reveal>07 / Since 2016</p>
          <h2 class="mt-4 max-w-3xl text-h2 tracking-tight text-balance" data-reveal>{origin.heading}</h2>
          <div class="mt-8 flex max-w-2xl flex-col gap-6">
            {
              origin.content?.map((block, i) => (
                <p class="text-lead text-slate" data-reveal style={`transition-delay: ${i * 80}ms`}>
                  {block.text}
                </p>
              ))
            }
          </div>
        </div>
      </section>
    )
  }

  <!-- 08 What honest measurement changes -->
  {
    results && (
      <section class="relative overflow-hidden bg-ink text-white">
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_80%_-10%,rgb(61_90_254/0.25),transparent_55%)]"
        />
        <div class="relative mx-auto max-w-7xl px-6 py-20 md:py-28 lg:px-20">
          <p class="gm-label text-white/60" data-reveal>08 / What Changes</p>
          <h2 class="mt-4 max-w-3xl text-h2 tracking-tight text-balance" data-reveal>{results.heading}</h2>

          <div class="mt-12 grid border-y border-white/12 sm:grid-cols-2 sm:divide-x sm:divide-white/12 lg:grid-cols-4" data-reveal>
            <div class="border-b border-white/12 px-2 py-8 sm:border-b-0 lg:px-6">
              <p class="font-display text-[clamp(1.75rem,3.2vw,2.75rem)] leading-[1] font-extrabold tracking-tighter">
                <span class="text-white/35"><span data-countup data-target="63">63</span>%</span>
                <span class="mx-2 text-white/25">to</span>
                <span class="text-cobalt"><span data-countup data-target="35">35</span>%</span>
              </p>
              <p class="mt-4 gm-label text-[10px] text-white/50">Conversions taking 90+ days</p>
            </div>
            <div class="border-b border-white/12 px-2 py-8 sm:border-b-0 lg:px-6">
              <p class="font-display text-[clamp(1.75rem,3.2vw,2.75rem)] leading-[1] font-extrabold tracking-tighter">
                <span class="text-white/35"><span data-countup data-target="5">5</span>%</span>
                <span class="mx-2 text-white/25">to</span>
                <span class="text-mint"><span data-countup data-target="22.6" data-decimals="1">22.6</span>%</span>
              </p>
              <p class="mt-4 gm-label text-[10px] text-white/50">Converting within two days</p>
            </div>
            <div class="border-b border-white/12 px-2 py-8 sm:border-b-0 lg:px-6">
              <p class="font-display text-[clamp(1.75rem,3.2vw,2.75rem)] leading-[1] font-extrabold tracking-tighter text-raspberry">
                <span data-countup data-target="23.15" data-decimals="2">23.15</span>%
              </p>
              <p class="mt-4 gm-label text-[10px] text-white/50">of onsemi conversions, GM-attributed</p>
            </div>
            <div class="px-2 py-8 lg:px-6">
              <p class="font-display text-[clamp(1.75rem,3.2vw,2.75rem)] leading-[1] font-extrabold tracking-tighter text-white">
                <span data-countup data-target="89">89</span>%
              </p>
              <p class="mt-4 gm-label text-[10px] text-white/50">Freed-Hardeman cost per conversion drop</p>
            </div>
          </div>

          <div class="mt-12 grid gap-10 lg:grid-cols-2 lg:gap-16">
            <div data-reveal>
              <p class="text-lead text-white/80">{resultsLead}</p>
              {
                resultsThesis && (
                  <p class="mt-8 font-display text-h3 leading-snug tracking-tight text-white">{resultsThesis}</p>
                )
              }
            </div>
            <div data-reveal style="transition-delay: 90ms">
              <p class="text-lead text-white/70">{results.content?.[1]?.text}</p>
              {
                pathOf(results.content?.[1]?.links) && (
                  <TextLink href={pathOf(results.content?.[1]?.links)!} arrow class="mt-6 text-white hover:text-white/70">
                    Read the case studies
                  </TextLink>
                )
              }
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- Sibling navigation -->
  <section class="bg-white" aria-label="More of the platform">
    <div class="mx-auto flex max-w-7xl flex-wrap items-center gap-x-10 gap-y-4 px-6 py-8 lg:px-20">
      <span class="gm-label text-[10px] text-mist">Keep reading</span>
      {siblings.map((s) => <TextLink href={s.href} arrow color="ink" underline={false}>{s.label}</TextLink>)}
    </div>
  </section>

  <!-- 09 FAQ -->
  {
    faq && (
      <section class="bg-cloud">
        <div class="mx-auto max-w-7xl px-6 py-16 md:py-24 lg:px-20">
          <div class="grid gap-10 lg:grid-cols-[1fr_2fr]">
            <div data-reveal>
              <p class="gm-label text-slate">09 / FAQ</p>
              <h2 class="mt-4 text-h2 tracking-tight text-balance">{faq.heading}</h2>
              <div class="mt-6 flex flex-col items-start gap-3">
                {
                  faqLinks.map((links) => {
                    const href = pathOf(links);
                    if (!href) return null;
                    return (
                      <TextLink href={href} arrow>
                        {href === "/glossary" ? "The glossary" : "The dashboard"}
                      </TextLink>
