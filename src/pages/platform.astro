---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";
import Button from "../components/ui/Button.astro";
import TextLink from "../components/ui/TextLink.astro";
import Icon from "../components/ui/Icon.astro";
import FAQAccordion from "../components/blocks/FAQAccordion.astro";

const page = await getEntry("pages", "platform");
if (!page) throw new Error("Missing content: src/content/pages/platform.json");
const data = page.data;

type Stat = {
  label?: string;
  before?: string;
  value?: string;
  tag?: string;
  accent?: string;
};
type LinkRef = { text: string; href: string };
type Block = {
  kind: string;
  text?: string;
  links?: string[];
  headers?: string[];
  rows?: string[][];
  href?: string;
  srLabel?: string;
};
type Section = {
  type: string;
  eyebrow?: string;
  heading?: string;
  content?: Block[];
  subsections?: { heading: string; content: Block[]; links?: string[] }[];
  link?: LinkRef;
  stats?: Stat[];
  metaTitle?: string;
  [key: string]: unknown;
};

const sections = data.sections as Section[];
const meta = sections.find((s) => s.type === "meta");
const hero = sections.find((s) => s.type === "hero");
const faq = sections.find((s) => s.type === "faq");
const contentSecs = sections.filter((s) => s.type === "section");
const features = contentSecs.find((s) => (s.subsections?.length ?? 0) > 0);
const comparison = contentSecs.find((s) => s.content?.some((c) => c.kind === "table"));
const ctaSec = contentSecs.find((s) => s.content?.some((c) => c.kind === "cta"));
const proseSecs = contentSecs.filter((s) => s !== features && s !== comparison && s !== ctaSec);
const [definition, problem, proof] = proseSecs;

// Inline CMS: absolute section indices, so data-cms-path stays correct even
// if sections are reordered in the content JSON later.
const heroIdx = hero ? sections.indexOf(hero) : -1;
const definitionIdx = definition ? sections.indexOf(definition) : -1;
const problemIdx = problem ? sections.indexOf(problem) : -1;
const featuresIdx = features ? sections.indexOf(features) : -1;
const comparisonIdx = comparison ? sections.indexOf(comparison) : -1;
const proofIdx = proof ? sections.indexOf(proof) : -1;
const faqIdx = faq ? sections.indexOf(faq) : -1;
const ctaIdx = ctaSec ? sections.indexOf(ctaSec) : -1;
const tableIdx = comparison?.content?.findIndex((c) => c.kind === "table") ?? -1;

const table = comparison?.content?.find((c) => c.kind === "table");
const comparisonParas = comparison?.content?.filter((c) => c.kind === "p") ?? [];
const comparisonPara0Idx = comparisonParas[0] ? comparison?.content?.indexOf(comparisonParas[0]) : -1;
const comparisonPara1Idx = comparisonParas[1] ? comparison?.content?.indexOf(comparisonParas[1]) : -1;

const heroParas = hero?.content?.filter((c) => c.kind === "p") ?? [];
const heroCta = hero?.content?.find((c) => c.kind === "cta");
const ctaParas = ctaSec?.content?.filter((c) => c.kind === "p") ?? [];
const ctaBtn = ctaSec?.content?.find((c) => c.kind === "cta");

const faqItems = (faq?.subsections ?? []).map((s, i) => ({
  question: s.heading,
  answer: s.content?.[0]?.text ?? "",
  open: i === 0,
}));

// Proof section: split the single paragraph into its two client stories at the
// "Country Thunder" sentence so each proof panel carries its own copy, verbatim.
const proofPara = proof?.content?.[0]?.text ?? "";
const ctIdx = proofPara.indexOf("Country Thunder");
const proofOnsemi = ctIdx > -1 ? proofPara.slice(0, ctIdx).trim() : proofPara;
const proofThunder = ctIdx > -1 ? proofPara.slice(ctIdx).trim() : "";
const proofClose = proof?.content?.[1];

// Split the two-sentence H1 so the second sentence can carry the raspberry accent
const title = data.title;
const splitAt = title.indexOf(". ");
const titleA = splitAt > -1 ? title.slice(0, splitAt + 1) : title;
const titleB = splitAt > -1 ? title.slice(splitAt + 2) : "";

// First path-shaped link on a block, e.g. "/glossary DSP entry" -> "/glossary"
const pathOf = (links?: string[]) => links?.find((l) => l.startsWith("/"))?.split(" ")[0];

const navLinks = [
  { label: "Platform", href: "/platform" },
  { label: "Solutions", href: "#" },
  { label: "Pricing", href: "#" },
  { label: "Resources", href: "#" },
];

// Trailing slash to match the URLs Astro emits in the sitemap
const pagePath = (((meta?.url as string) ?? "/platform") + "/").replace(/\/+$/, "/");
const siteUrl = Astro.site?.href ?? "https://geniusmonkey.com/";
const pageUrl = new URL(pagePath, siteUrl).href;

// Structured data: Organization + WebPage + Breadcrumb + FAQPage, all from the content JSON
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}#organization`,
      name: "Genius Monkey",
      url: siteUrl,
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: meta?.metaTitle ?? data.title,
      description: data.seoDescription,
      isPartOf: { "@id": `${siteUrl}#organization` },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
        { "@type": "ListItem", position: 2, name: "Platform", item: pageUrl },
      ],
    },
    {
      "@type": "FAQPage",
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ],
};
---

<BaseLayout
  title={meta?.metaTitle ?? data.title}
  description={data.seoDescription}
  path={pagePath}
  cmsPage="platform"
  cmsSeed={data}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <Navbar links={navLinks} />

  <main id="main-content">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-ink text-white">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 bg-[repeating-linear-gradient(90deg,rgb(255_255_255/0.03)_0_1px,transparent_1px_120px)]"
    >
    </div>
    <p
      aria-hidden="true"
      class="pointer-events-none absolute -right-8 -bottom-16 font-display text-[clamp(10rem,26vw,22rem)] leading-none font-extrabold tracking-tighter text-white/4 select-none"
    >
      GM.
    </p>
    <div class="relative mx-auto max-w-7xl px-6 pt-20 pb-24 md:pt-28 md:pb-32 lg:px-20">
      <p class="gm-label rise text-raspberry" data-cms-path={`sections.${heroIdx}.eyebrow`}>{hero?.eyebrow}</p>
      <h1 class="rise mt-6 max-w-4xl font-display text-[clamp(2.5rem,6.5vw,5.5rem)] leading-[0.98] font-extrabold tracking-tight" style="animation-delay: 90ms">
        {titleA}{titleB && <> <span class="text-raspberry">{titleB}</span></>}
      </h1>
      <div class="mt-10 grid gap-10 lg:grid-cols-[minmax(0,34rem)_1fr]">
        <p class="rise text-lead text-white/70" style="animation-delay: 180ms" data-cms-path={`sections.${heroIdx}.content.0.text`}>
          {heroParas[0]?.text}
        </p>
        <div class="rise flex items-start lg:justify-end" style="animation-delay: 260ms">
          {heroCta && (
            <Button size="lg" href={heroCta.href ?? "/request-a-demo"} icon="arrow-right">
              <span data-cms-path={`sections.${heroIdx}.content.1.text`}>{heroCta.text}</span>
            </Button>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Definition -->
  {
    definition && (
      <section class="bg-white">
        <div class="mx-auto grid max-w-7xl gap-10 px-6 py-16 md:py-24 lg:grid-cols-[1fr_2fr] lg:px-20">
          <div>
            <p class="gm-label text-slate" data-cms-path={`sections.${definitionIdx}.eyebrow`}>{definition.eyebrow}</p>
            <h2 class="mt-4 text-h2 tracking-tight text-balance" data-cms-path={`sections.${definitionIdx}.heading`}>
              {definition.heading}
            </h2>
          </div>
          <div class="lg:pt-12">
            <div class="border-l-4 border-raspberry pl-6">
              <p class="text-lead text-ink" data-cms-path={`sections.${definitionIdx}.content.0.text`}>
                {definition.content?.[0]?.text}
              </p>
            </div>
            <p class="mt-6 text-body text-slate">
              <span data-cms-path={`sections.${definitionIdx}.content.1.text`}>{definition.content?.[1]?.text}</span>
              {definition.link && (
                <TextLink href={definition.link.href} class="ml-2">
                  <span data-cms-path={`sections.${definitionIdx}.link.text`}>{definition.link.text}</span>
                </TextLink>
              )}
            </p>
          </div>
        </div>
      </section>
    )
  }

  <!-- Problem -->
  {
    problem && (
      <section class="bg-gradient-dark-raspberry text-white">
        <div class="mx-auto max-w-7xl px-6 py-20 md:py-28 lg:px-20">
          <p class="gm-label text-white/60" data-cms-path={`sections.${problemIdx}.eyebrow`}>{problem.eyebrow}</p>
          <h2 class="mt-4 max-w-3xl font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.05] font-extrabold tracking-tight text-balance" data-cms-path={`sections.${problemIdx}.heading`}>
            {problem.heading}
          </h2>
          <div class="mt-10 flex max-w-2xl flex-col gap-6 lg:ml-[18%]">
            {problem.content?.map((block, i) => (
              <p class="text-lead text-white/80" data-cms-path={`sections.${problemIdx}.content.${i}.text`}>{block.text}</p>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Features index -->
  {
    features && (
      <section class="bg-cloud">
        <div class="mx-auto max-w-7xl px-6 py-16 md:py-24 lg:px-20">
          <p class="gm-label text-slate" data-cms-path={`sections.${featuresIdx}.eyebrow`}>{features.eyebrow}</p>
          <h2 class="mt-4 max-w-xl text-h2 tracking-tight text-balance" data-cms-path={`sections.${featuresIdx}.heading`}>
            {features.heading}
          </h2>
          <div class="mt-12 grid gap-4 md:grid-cols-2">
            {features.subsections?.map((sub, i) => {
              const href = pathOf(sub.links) ?? "#";
              const anchor = i === 0;
              return anchor ? (
                <a
                  href={href}
                  class="group flex flex-col justify-between gap-12 bg-ink p-8 text-white transition-colors hover:bg-ink-800 md:row-span-2 md:p-10"
                >
                  <div>
                    <span class="font-display text-6xl font-extrabold tracking-tighter text-raspberry">01</span>
                    <h3 class="mt-5 text-h3 tracking-tight transition-colors group-hover:text-raspberry">
                      <span data-cms-path={`sections.${featuresIdx}.subsections.${i}.heading`}>{sub.heading}</span>
                    </h3>
                    <p class="mt-5 max-w-md text-body text-white/65" data-cms-path={`sections.${featuresIdx}.subsections.${i}.content.0.text`}>
                      {sub.content?.[0]?.text}
                    </p>
                  </div>
                  <span class="grid size-10 shrink-0 place-items-center self-end rounded-full border-2 border-white/30 text-white transition-all group-hover:border-raspberry group-hover:bg-raspberry">
                    <Icon name="arrow-right" size={16} />
                  </span>
                </a>
              ) : (
                <a href={href} class="group flex flex-col border border-line bg-white p-8 transition-colors hover:border-ink">
                  <span class="gm-label text-[10px] text-raspberry">{String(i + 1).padStart(2, "0")}</span>
                  <h3 class="mt-2 text-h4 tracking-tight transition-colors group-hover:text-raspberry">
                    <span data-cms-path={`sections.${featuresIdx}.subsections.${i}.heading`}>{sub.heading}</span>
                  </h3>
                  <p class="mt-4 grow text-body text-slate" data-cms-path={`sections.${featuresIdx}.subsections.${i}.content.0.text`}>
                    {sub.content?.[0]?.text}
                  </p>
                  <span class="mt-6 grid size-10 shrink-0 place-items-center self-end rounded-full border-2 border-line text-ink transition-all group-hover:border-raspberry group-hover:bg-raspberry group-hover:text-white">
                    <Icon name="arrow-right" size={16} />
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )
  }

  <!-- Comparison -->
  {
    comparison && table && (
      <section class="bg-white">
        <div class="mx-auto max-w-7xl px-6 py-16 md:py-24 lg:px-20">
          <div class="grid gap-10 lg:grid-cols-[1fr_2fr]">
            <div>
              <p class="gm-label text-slate" data-cms-path={`sections.${comparisonIdx}.eyebrow`}>{comparison.eyebrow}</p>
              <h2 class="mt-4 text-h2 tracking-tight text-balance" data-cms-path={`sections.${comparisonIdx}.heading`}>
                {comparison.heading}
              </h2>
              <p class="mt-6 text-body text-slate" data-cms-path={`sections.${comparisonIdx}.content.${comparisonPara0Idx}.text`}>
                {comparisonParas[0]?.text}
              </p>
              {comparisonParas[1] && (
                <div class="mt-8 border-l-4 border-raspberry pl-5">
                  <p class="text-lead font-semibold text-ink" data-cms-path={`sections.${comparisonIdx}.content.${comparisonPara1Idx}.text`}>
                    {comparisonParas[1].text}
                  </p>
                </div>
              )}
            </div>
            <div class="lg:pt-12">
              <div class="overflow-x-auto">
                <table class="w-full min-w-130 border-collapse text-left">
                  <thead>
                    <tr>
                      {[0, 2, 1].map((col) => {
                        const h = table.headers?.[col];
                        return (
                          <th
                            class:list={[
                              "border-b-2 border-ink px-4 py-3 text-sm font-bold",
                              col === 2 && "bg-raspberry text-white",
                              col === 1 && "text-slate",
                            ]}
                            data-cms-path={h ? `sections.${comparisonIdx}.content.${tableIdx}.headers.${col}` : undefined}
                          >
                            {h || <span class="sr-only" data-cms-path={`sections.${comparisonIdx}.content.${tableIdx}.srLabel`}>{table.srLabel}</span>}
                          </th>
                        );
                      })}
                    </tr>
                  </thead>
                  <tbody>
                    {table.rows?.map((row, r) => (
                      <tr class="border-b border-line">
                        {[0, 2, 1].map((col) => (
                          <td
                            class:list={[
                              "px-4 py-4 text-sm",
                              col === 0 && "font-bold",
                              col === 1 && "text-slate",
                              col === 2 && "bg-raspberry-100/40 font-semibold",
                            ]}
                            data-cms-path={`sections.${comparisonIdx}.content.${tableIdx}.rows.${r}.${col}`}
                          >
                            {row[col]}
                          </td>
                        ))}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- Proof -->
  {
    proof && (
      <section class="bg-ink text-white">
        <div class="mx-auto max-w-7xl px-6 py-20 md:py-28 lg:px-20">
          <p class="gm-label text-white/60" data-cms-path={`sections.${proofIdx}.eyebrow`}>{proof.eyebrow}</p>
          <h2 class="mt-4 text-h2 tracking-tight" data-cms-path={`sections.${proofIdx}.heading`}>{proof.heading}</h2>

          <div class="mt-12 grid border-y border-white/12 lg:grid-cols-2 lg:divide-x lg:divide-white/12">
            <div class="flex flex-col items-start gap-6 border-b border-white/12 py-12 lg:border-b-0 lg:pr-14">
              <p class="gm-label text-[10px] text-white/50" data-cms-path={`sections.${proofIdx}.stats.0.label`}>
                {proof.stats?.[0]?.label}
              </p>
              <p class="font-display leading-[0.95] font-extrabold tracking-tighter">
                <span
                  class="block text-[clamp(2.5rem,4.5vw,4rem)] text-white/30 line-through decoration-raspberry decoration-4"
                  data-cms-path={`sections.${proofIdx}.stats.0.before`}
                >
                  {proof.stats?.[0]?.before}
                </span>
                <span class="block text-[clamp(4rem,8vw,7rem)] text-raspberry" data-cms-path={`sections.${proofIdx}.stats.0.value`}>
                  {proof.stats?.[0]?.value}
                </span>
              </p>
              <p class="inline-block bg-raspberry px-3 py-1.5 gm-label text-[10px]" data-cms-path={`sections.${proofIdx}.stats.0.tag`}>
                {proof.stats?.[0]?.tag}
              </p>
              <!-- proofOnsemi is a client-side slice of the shared content.0 paragraph
                   (see proofThunder below); bound here as the representative node. -->
              <p class="max-w-md text-body text-white/70" data-cms-path={`sections.${proofIdx}.content.0.text`}>{proofOnsemi}</p>
            </div>

            <div class="flex flex-col items-start gap-6 py-12 lg:pl-14">
              <p class="gm-label text-[10px] text-white/50" data-cms-path={`sections.${proofIdx}.stats.1.label`}>
                {proof.stats?.[1]?.label}
              </p>
              <p class="font-display leading-[0.95] font-extrabold tracking-tighter">
                <span class="block text-[clamp(2.5rem,4.5vw,4rem)] text-white" data-cms-path={`sections.${proofIdx}.stats.1.before`}>
                  {proof.stats?.[1]?.before}
                </span>
                <span class="block text-[clamp(4rem,8vw,7rem)] text-mint" data-cms-path={`sections.${proofIdx}.stats.1.value`}>
                  {proof.stats?.[1]?.value}
                </span>
              </p>
              <p class="inline-block bg-mint px-3 py-1.5 gm-label text-[10px] text-ink" data-cms-path={`sections.${proofIdx}.stats.1.tag`}>
                {proof.stats?.[1]?.tag}
              </p>
              <p class="max-w-md text-body text-white/70">{proofThunder}</p>
            </div>
          </div>

          {proofClose && (
            <div class="mt-10 flex flex-wrap items-center gap-x-3 gap-y-4">
              <p class="text-lead text-white/80" data-cms-path={`sections.${proofIdx}.content.1.text`}>{proofClose.text}</p>
              {proof.link && (
                <TextLink href={proof.link.href} arrow class="text-white hover:text-white/70">
                  <span data-cms-path={`sections.${proofIdx}.link.text`}>{proof.link.text}</span>
                </TextLink>
              )}
            </div>
          )}
        </div>
      </section>
    )
  }

  <!-- FAQ -->
  {
    faq && (
      <section class="bg-cloud">
        <div class="mx-auto max-w-7xl px-6 py-16 md:py-24 lg:px-20">
          <div class="grid gap-10 lg:grid-cols-[1fr_2fr]">
            <div>
              <p class="gm-label text-slate" data-cms-path={`sections.${faqIdx}.eyebrow`}>{faq.eyebrow}</p>
              <h2 class="mt-4 text-h2 tracking-tight text-balance" data-cms-path={`sections.${faqIdx}.heading`}>
                {faq.heading}
              </h2>
            </div>
            <FAQAccordion items={faqItems} class="lg:mt-2" basePath={`sections.${faqIdx}.subsections`} />
          </div>
        </div>
      </section>
    )
  }

  <!-- CTA -->
  {
    ctaSec && (
      <section class="relative overflow-hidden bg-ink text-white">
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_85%_120%,rgb(247_0_78/0.45),transparent_55%)]"
        />
        <div class="relative mx-auto max-w-7xl px-6 py-20 md:py-28 lg:px-20">
          <h2 class="max-w-2xl font-display text-[clamp(2.5rem,5.5vw,4.5rem)] leading-[1.02] font-extrabold tracking-tight" data-cms-path={`sections.${ctaIdx}.heading`}>
            {ctaSec.heading}
          </h2>
          <div class="mt-8 grid gap-10 lg:grid-cols-[minmax(0,34rem)_1fr]">
            <p class="text-lead text-white/75" data-cms-path={`sections.${ctaIdx}.content.0.text`}>{ctaParas[0]?.text}</p>
            <div class="flex items-start lg:justify-end">
              {ctaBtn && (
                <Button size="lg" href={ctaBtn.href ?? "/request-a-demo"} icon="arrow-right">
                  <span data-cms-path={`sections.${ctaIdx}.content.1.text`}>{ctaBtn.text}</span>
                </Button>
              )}
            </div>
          </div>
        </div>
      </section>
    )
  }

  </main>

  <Footer />
</BaseLayout>

<style>
  @keyframes gm-rise {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
  }
  .rise {
    animation: gm-rise 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @media (prefers-reduced-motion: reduce) {
    .rise {
      animation: none;
    }
  }
</style>
