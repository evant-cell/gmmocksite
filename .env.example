# Firebase Web SDK config (client-side).
# These values are PUBLIC identifiers by design, not secrets - they ship in the
# client bundle. Real protection comes from Firebase Auth provider settings and
# Firestore Security Rules, not from hiding these. The PUBLIC_ prefix is required
# so Astro/Vite exposes them to client scripts.
# Find these in Firebase console -> Project settings -> Your apps -> SDK setup.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
