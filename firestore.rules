rules_version = '2';

// Security rules for the mock site. Client-side route guards are UX only; these
// rules are the real access boundary for the mocksite-user collection.
service cloud.firestore {
  match /databases/{database}/documents {

    match /mocksite-user/{userId} {
      // A signed-in user can read their own profile document.
      allow read: if request.auth != null && request.auth.uid == userId;

      // On signup a user may create only their own doc, and only as a `member`.
      // This prevents a client from self-assigning `editor` or `admin`.
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == 'member';

      // A user may update their own doc but may NOT change their role.
      // Role changes (editor/admin) are done out-of-band (console / trusted admin).
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == resource.data.role;

      allow delete: if false;
    }

    // Inline CMS content overlay for the home and platform pages. Content is
    // public regardless (it mirrors the built-in JSON), so reads stay open -
    // that also lets onSnapshot run for anonymous visitors. Writes require an
    // editor/admin role, resolved from the caller's own mocksite-user doc.
    match /pages-main/{slug} {
      allow read: if true;
      allow create, update: if request.auth != null
                    && get(/databases/$(database)/documents/mocksite-user/$(request.auth.uid)).data.role in ['editor', 'admin'];
      allow delete: if false;
    }
  }
}
